<% let path='/my-bookings'; let title=__('site.title.myBookings'); %>
<%- include('partials/header', { path, title }) %>

<style>
  .status-badge { display:inline-block; padding:3px 12px; border-radius:12px; font-size:12px; font-weight:bold; }
  .status-pending { background:#fff3cd; color:#856404; }
  .status-confirmed { background:#d4edda; color:#155724; }
  .status-completed { background:#cce5ff; color:#004085; }
  .status-cancelled { background:#f8d7da; color:#721c24; }
</style>

<div style="padding-top:60px;max-width:1200px;margin:0 auto;padding-left:15px;padding-right:15px;">
  <div style="display:flex;justify-content:space-between;align-items:center;margin:25px 0;flex-wrap:wrap;gap:10px;">
    <h1 style="color:#333;margin:0;">📋 <%= __('myBookings.title') %></h1>
    <a href="/" style="padding:8px 20px;background:#59b200;color:#fff;border-radius:4px;text-decoration:none;">🏠 <%= __('myBookings.continue') %></a>
  </div>

  <% if (bookings.length === 0) { %>
    <div style="text-align:center;padding:80px 20px;background:#fff;border-radius:8px;border:1px solid #eee;">
      <div style="font-size:60px;margin-bottom:15px;">📭</div>
      <h2 style="color:#666;font-size:20px;margin:0 0 10px;"><%= __('myBookings.noBookings') %></h2>
      <p style="color:#888;font-size:14px;margin-bottom:20px;"><%= __('myBookings.noBookingsDesc') %></p>
      <a href="/" style="padding:12px 35px;background:#59b200;color:#fff;border-radius:6px;text-decoration:none;"><%= __('myBookings.browse') %></a>
    </div>
  <% } else { %>
    <div style="display:grid;gap:20px;">
      <% bookings.forEach(function(b) { %>
        <div style="background:#fff;border:1px solid #eee;border-radius:8px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.04);">
          <div style="display:flex;flex-wrap:wrap;">
            <div style="width:200px;flex-shrink:0;">
              <img src="/img/<%= b.image %>" alt="" style="width:100%;height:150px;object-fit:cover;">
            </div>
            <div style="flex:1;padding:20px;min-width:300px;">
              <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:10px;">
                <div>
                  <h3 style="margin:0 0 5px;color:#333;font-size:16px;"><%= isEn && b.tour_title_en ? b.tour_title_en : b.tour_title %></h3>
                  <div style="color:#888;font-size:13px;">
                    <span>🗓️ <%= b.travel_date %></span>
                    <span style="margin-left:15px;">👤 <%= b.adults %><%= __('myBookings.adults') %><%= b.children > 0 ? ' + ' + b.children + __('myBookings.children') : '' %></span>
                    <span style="margin-left:15px;">📅 <%= b.days || '' %></span>
                  </div>
                </div>
                <span class="status-badge status-<%= b.status %>">
                  <% if (b.status === 'pending') { %>⏳ <%= __('myBookings.pending') %>
                  <% } else if (b.status === 'confirmed') { %>✅ <%= __('myBookings.confirmed') %>
                  <% } else if (b.status === 'completed') { %>✔️ <%= __('myBookings.completed') %>
                  <% } else { %>❌ <%= __('myBookings.cancelled') %><% } %>
                </span>
              </div>
              <div style="margin-top:15px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
                <div style="color:#888;font-size:13px;">
                  📞 <%= b.phone %>
                  <% if (b.email) { %> | 📧 <%= b.email %><% } %>
                </div>
                <div style="color:#ff6600;font-size:22px;font-weight:bold;">¥<%= b.total_price.toFixed(0) %></div>
              </div>
              <% if (b.note) { %>
                <div style="margin-top:10px;padding:8px 12px;background:#f9f9f9;border-radius:4px;font-size:13px;color:#888;">
                  📝 <%= __('myBookings.note') %>：<%= b.note %>
                </div>
              <% } %>
              <div style="margin-top:12px;font-size:12px;color:#bbb;">
                <%= __('myBookings.orderId') %>：#<%= b.id %> | <%= __('myBookings.submitted') %>：<%= new Date(b.created_at).toLocaleString(isEn ? 'en-US' : 'zh-CN') %>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
