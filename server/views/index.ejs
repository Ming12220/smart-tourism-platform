<% let path='/'; let title=__('site.title.home'); %>
<%- include('partials/header', { path, title }) %>

<style>
  /* === Hero === */
  .hero-section {
    position: relative; width: 100%; height: 85vh; min-height: 500px; max-height: 700px; overflow: hidden;
  }
  .hero-section .swiper-slide img {
    width: 100%; height: 100%; object-fit: cover; filter: brightness(0.7);
  }
  .hero-overlay {
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(135deg, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.1) 100%);
    z-index: 2; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px;
  }
  .hero-overlay h1 {
    color: #fff; font-size: 48px; font-weight: 700; text-shadow: 0 2px 20px rgba(0,0,0,0.3);
    margin-bottom: 10px; text-align: center;
  }
  .hero-overlay p {
    color: rgba(255,255,255,0.9); font-size: 18px; margin-bottom: 30px; text-align: center;
  }
  .hero-search {
    display: flex; max-width: 600px; width: 90%;
    background: rgba(255,255,255,0.95); border-radius: 50px; overflow: hidden; box-shadow: 0 10px 40px rgba(0,0,0,0.2);
  }
  .hero-search input {
    flex: 1; border: none; padding: 16px 25px; font-size: 16px; outline: none; background: transparent;
  }
  .hero-search button {
    padding: 16px 35px; background: linear-gradient(135deg, #ff6600, #ff4500);
    color: #fff; border: none; font-size: 16px; font-weight: bold; cursor: pointer; transition: 0.3s;
  }
  .hero-search button:hover { opacity: 0.9; }

  /* === Section Titles === */
  .section-wrap { max-width: 1400px; margin: 0 auto; padding: 0 15px; }
  .section-title {
    text-align: center; padding: 50px 15px 10px; position: relative;
  }
  .section-title h2 {
    font-size: 32px; color: #2c3e50; margin: 0; font-weight: 700;
  }
  .section-title p { color: #95a5a6; font-size: 15px; margin: 8px 0 0; }
  .section-title::after {
    content: ''; display: block; width: 60px; height: 3px;
    background: linear-gradient(90deg, #59b200, #ff6600); margin: 15px auto 0; border-radius: 2px;
  }

  /* === Stats === */
  .stats-bar {
    display: flex; justify-content: center; gap: 60px; padding: 35px 15px; background: #f8f9fa;
    flex-wrap: wrap; border-bottom: 1px solid #eee;
  }
  .stats-bar .stat-item { text-align: center; }
  .stats-bar .stat-item .num { font-size: 32px; font-weight: 700; color: #59b200; }
  .stats-bar .stat-item .label { font-size: 13px; color: #7f8c8d; margin-top: 4px; }

  /* === Tour Grid & Cards === */
  .tour-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 25px;
    max-width: 1400px; margin: 0 auto; padding: 20px 15px;
  }
  .tour-card {
    background: #fff; border-radius: 14px; overflow: hidden;
    box-shadow: 0 2px 15px rgba(0,0,0,0.05); transition: all 0.35s ease;
    border: 1px solid #f0f0f0; height: 100%;
  }
  .tour-card:hover {
    transform: translateY(-6px); box-shadow: 0 15px 40px rgba(0,0,0,0.12);
  }
  .tour-card .card-img {
    position: relative; height: 220px; overflow: hidden;
  }
  .tour-card .card-img img {
    width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s;
  }
  .tour-card:hover .card-img img { transform: scale(1.08); }
  .tour-card .card-img .tag {
    position: absolute; top: 12px; left: 0;
    background: #59b200; color: #fff; padding: 4px 14px; font-size: 12px; font-weight: 600;
    border-radius: 0 4px 4px 0;
  }
  .tour-card .card-img .tag-promo {
    position: absolute; top: 12px; right: 12px;
    background: #ff6600; color: #fff; padding: 3px 10px; font-size: 11px; font-weight: 600;
    border-radius: 4px; box-shadow: 0 2px 8px rgba(255,102,0,0.3);
  }
  .tour-card .card-body { padding: 18px 20px; }
  .tour-card .card-body h3 {
    font-size: 16px; color: #2c3e50; margin: 0 0 8px;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 600;
  }
  .tour-card .card-body .desc {
    color: #7f8c8d; font-size: 13px; line-height: 1.5; margin: 0 0 14px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .tour-card .card-body .meta {
    display: flex; justify-content: space-between; align-items: center;
    padding-top: 14px; border-top: 1px solid #f0f0f0;
  }
  .tour-card .card-body .meta .price { color: #ff6600; font-size: 14px; font-weight: 600; }
  .tour-card .card-body .meta .price b { font-size: 22px; }
  .tour-card .card-body .meta .rating { color: #95a5a6; font-size: 13px; }

  /* === Promotion Section === */
  .promo-section {
    background: linear-gradient(135deg, #fff4e6 0%, #ffe8d6 100%);
    padding: 20px 0 40px; margin-top: 30px;
  }
  .promo-section .section-title h2 { color: #e65100; }
  .promo-section .section-title::after { background: linear-gradient(90deg, #ff6600, #ff4500); }

  /* === Destinations Grid === */
  .dest-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(165px, 1fr));
    gap: 16px; max-width: 1400px; margin: 0 auto; padding: 20px 15px 50px;
  }
  .dest-card {
    background: #fff; border: 1px solid #f0f0f0; border-radius: 14px;
    padding: 22px 12px; text-align: center; transition: all 0.3s ease;
    cursor: pointer; text-decoration: none; color: inherit;
  }
  .dest-card:hover {
    transform: translateY(-5px); box-shadow: 0 12px 30px rgba(0,0,0,0.1);
    border-color: #59b200;
  }
  .dest-card .emoji { font-size: 36px; margin-bottom: 8px; display: block; }
  .dest-card .name { font-size: 14px; font-weight: 600; color: #2c3e50; margin-bottom: 4px; }
  .dest-card .tags { font-size: 12px; color: #95a5a6; }

  /* === CTA Banner === */
  .cta-banner {
    max-width: 1400px; margin: 30px auto; padding: 0 15px;
  }
  .cta-banner-inner {
    background: linear-gradient(135deg, #59b200, #3d8a00);
    border-radius: 18px; padding: 35px 45px;
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 20px;
    box-shadow: 0 10px 35px rgba(89,178,0,0.25); transition: all 0.3s;
  }
  .cta-banner-inner:hover {
    transform: translateY(-3px); box-shadow: 0 15px 45px rgba(89,178,0,0.35);
  }
  .cta-text h3 { font-size: 20px; font-weight: 700; color: #fff; margin: 0 0 6px; }
  .cta-text p { font-size: 14px; color: rgba(255,255,255,0.9); margin: 0; }
  .cta-phone { text-align: right; }
  .cta-phone .num { font-size: 24px; font-weight: 700; color: #fff; }
  .cta-phone .hours { font-size: 12px; color: rgba(255,255,255,0.8); }
  .cta-btn {
    background: #fff; color: #59b200; padding: 12px 30px; border-radius: 30px;
    font-size: 15px; font-weight: 700; text-decoration: none; transition: 0.3s;
  }
  .cta-btn:hover { transform: scale(1.05); box-shadow: 0 4px 15px rgba(0,0,0,0.15); }

  /* === Floating Buttons === */
  .float-btn {
    position: fixed; width: 48px; height: 48px; right: 25px; z-index: 999;
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    text-decoration: none; border: none; cursor: pointer;
    box-shadow: 0 4px 15px rgba(0,0,0,0.25); transition: all 0.3s; font-size: 20px;
    color: #fff;
  }
  .float-btn:hover { transform: translateY(-3px); box-shadow: 0 6px 25px rgba(0,0,0,0.3); }
  .float-top { bottom: 30px; background: #59b200; display: none; }
  .float-kefu { bottom: 90px; background: linear-gradient(135deg, #ff6600, #ff4500); }

  /* === Responsive === */
  @media (max-width: 768px) {
    .hero-overlay h1 { font-size: 28px; }
    .hero-overlay p { font-size: 14px; }
    .hero-section { height: 60vh; min-height: 400px; }
    .tour-grid { grid-template-columns: 1fr; gap: 18px; }
    .dest-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px; }
    .stats-bar { gap: 25px; }
    .section-title h2 { font-size: 24px; }
    .cta-banner-inner { flex-direction: column; text-align: center; padding: 25px 20px; }
    .cta-phone { text-align: center; }
  }
</style>

<!-- ========== HERO ========== -->
<div class="hero-section">
  <div class="swiper-container" style="width:100%;height:100%;">
    <div class="swiper-wrapper">
      <div class="swiper-slide"><img src="/img/search.jpg" alt="旅游推荐"></div>
      <div class="swiper-slide"><img src="/img/t10.jpg" alt="黄山"></div>
      <div class="swiper-slide"><img src="/img/t11.jpg" alt="九寨沟"></div>
    </div>
    <div class="swiper-pagination"></div>
  </div>
  <div class="hero-overlay">
    <h1><%= __('home.hero.title') %></h1>
    <p><%= __('home.hero.subtitle') %></p>
    <form class="hero-search" action="/search<%= isEn ? '?lang=en' : '' %>" method="GET" onsubmit="return goSearch()">
      <input type="text" name="q" id="searchInput" placeholder="🔍 <%= __('home.hero.search') %>" autocomplete="off">
      <button type="submit"><%= __('home.hero.searchBtn') %></button>
    </form>
  </div>
</div>

<!-- ========== STATS ========== -->
<div class="stats-bar">
  <div class="stat-item"><div class="num">19</div><div class="label"><%= isEn ? 'Selected Tours' : '精选线路' %></div></div>
  <div class="stat-item"><div class="num">10+</div><div class="label"><%= isEn ? 'Destinations' : '热门目的地' %></div></div>
  <div class="stat-item"><div class="num">96%</div><div class="label"><%= isEn ? 'Satisfaction' : '平均满意度' %></div></div>
  <div class="stat-item"><div class="num">24h</div><div class="label"><%= isEn ? 'Online Service' : '客服在线' %></div></div>
</div>

<!-- ========== PROMOTIONS ========== -->
<div class="promo-section">
  <div class="section-title">
    <h2>🔥 <%= __('home.promotions') %></h2>
    <p><%= __('home.promotionsDesc') %></p>
  </div>
  <div class="tour-grid" style="padding-top:10px;">
    <% hotTours.filter(t => t.is_promotion).slice(0, 3).forEach(function(tour) { %>
      <a href="/tour/<%= tour.id %><%= isEn ? '?lang=en' : '' %>" style="text-decoration:none;color:inherit;">
        <div class="tour-card">
          <div class="card-img">
            <img src="/img/<%= tour.image %>" alt="<%= tt(tour, 'title') %>">
            <span class="tag"><%= tt(tour, 'type_label') %></span>
            <span class="tag-promo"><%= isEn ? 'SALE' : '特价' %></span>
          </div>
          <div class="card-body">
            <h3><%= tt(tour, 'title') %></h3>
            <p class="desc"><%= tt(tour, 'description') %></p>
            <div class="meta">
              <span class="price">¥&nbsp;<b><%= tour.price %></b><%= isEn ? " from" : "起" %>
                <% if (tour.original_price > tour.price) { %>
                  <span style="font-size:12px;text-decoration:line-through;color:#bbb;font-weight:normal;">¥<%= tour.original_price %></span>
                <% } %>
              </span>
              <span class="rating">⭐ <%= tour.satisfaction %></span>
            </div>
          </div>
        </div>
      </a>
    <% }) %>
  </div>
</div>

<!-- ========== HOT TOURS ========== -->
<div class="section-title">
  <h2>🏝️ <%= __('home.hotTours') %></h2>
  <p><%= __('home.hotToursDesc') %></p>
</div>

<div class="tour-grid" style="padding-bottom:30px;">
  <% hotTours.forEach(function(tour) { %>
    <a href="/tour/<%= tour.id %><%= isEn ? '?lang=en' : '' %>" style="text-decoration:none;color:inherit;">
      <div class="tour-card">
        <div class="card-img">
          <img src="/img/<%= tour.image %>" alt="<%= tt(tour, 'title') %>">
          <span class="tag"><%= tt(tour, 'type_label') %></span>
          <% if (tour.is_promotion) { %>
            <span class="tag-promo"><%= isEn ? 'SALE' : '特价' %></span>
          <% } %>
        </div>
        <div class="card-body">
          <h3><%= tt(tour, 'title') %></h3>
          <p class="desc"><%= tt(tour, 'description') %></p>
          <div class="meta">
            <span class="price">¥&nbsp;<b><%= tour.price %></b><%= isEn ? " from" : "起" %></span>
            <span class="rating">⭐ <%= tour.satisfaction %></span>
          </div>
        </div>
      </div>
    </a>
  <% }) %>
</div>

<!-- ========== CATEGORIES ========== -->
<div class="section-title" style="padding-top:20px;">
  <h2>📂 <%- isEn ? 'Categories' : '线路分类' %></h2>
  <p><%- isEn ? 'Browse by category' : '按分类浏览线路' %></p>
</div>
<div class="dest-grid" style="padding-bottom:30px;">
  <% categories.forEach(function(cat) { %>
    <a href="/<%= isEn ? 'gwjd' : 'zmzg' %>" class="dest-card">
      <span class="emoji">
        <% if (cat.slug === 'domestic-long' || cat.slug === 'domestic-short') { %>🏔️<% } %>
        <% if (cat.slug === 'abroad-long') { %>🌍<% } %>
        <% if (cat.slug === 'self-tour') { %>🚶<% } %>
        <% if (cat.slug === 'cruise') { %>🚢<% } %>
      </span>
      <div class="name"><%= tc(cat) %></div>
      <div class="tags"><%= isEn ? 'View tours' : '查看线路' %> →</div>
    </a>
  <% }) %>
</div>

<!-- ========== CTA ========== -->
<div class="cta-banner">
  <a href="/kefu" style="text-decoration:none;display:block;">
    <div class="cta-banner-inner">
      <div class="cta-text">
        <h3>💬 <%= isEn ? 'Need Help? We\'re Online!' : '需要帮助？我们在线！' %></h3>
        <p><%= isEn ? 'Professional travel consultants, one-on-one service' : '专业旅游顾问 · 一对一服务 · 全天候在线' %></p>
      </div>
      <div class="cta-phone">
        <div class="num">400-888-9999</div>
        <div class="hours"><%= __('kefu.contactHours') %></div>
      </div>
      <span class="cta-btn"><%= isEn ? 'Chat Now' : '咨询客服' %> →</span>
    </div>
  </a>
</div>

<!-- ========== DESTINATIONS ========== -->
<div class="section-title" style="padding-top:10px;">
  <h2>🌍 <%= isEn ? 'Popular Destinations' : '热门目的地' %></h2>
  <p><%= isEn ? 'Explore popular destinations around the world' : '精选全球热门旅游目的地' %></p>
</div>

<div class="dest-grid">
  <% var destinations = [
    {nameEn:'Huangshan Mountain', nameCn:'黄山 · 天下第一奇山', emoji:'🏔️', tourId:10, descEn:'Welcoming Pine · Sea of Clouds', descCn:'迎客松·云海·日出'},
    {nameEn:'Jiuzhaigou Valley', nameCn:'九寨沟 · 人间仙境', emoji:'🌊', tourId:11, descEn:'Five Flower Lake · Waterfalls', descCn:'五花海·诺日朗瀑布'},
    {nameEn:'Sanya Paradise', nameCn:'三亚 · 天涯海角', emoji:'🏝️', tourId:12, descEn:'Wuzhizhou · Yalong Bay', descCn:'蜈支洲岛·亚龙湾'},
    {nameEn:'Lijiang Ancient Town', nameCn:'丽江 · 玉龙雪山', emoji:'🏯', tourId:13, descEn:'Old Town · Jade Dragon Snow', descCn:'古城·雪山·束河'},
    {nameEn:'Zhangjiajie', nameCn:'张家界 · 阿凡达', emoji:'🏔️', tourId:14, descEn:'Avatar Mountains · Glass Walk', descCn:'袁家界·天门山'},
    {nameEn:'Guilin Landscape', nameCn:'桂林 · 山水甲天下', emoji:'🎋', tourId:15, descEn:'Li River · Yangshuo', descCn:'漓江·阳朔·竹筏'},
    {nameEn:'Xi\'an Ancient Capital', nameCn:'西安 · 千年古都', emoji:'🛕', tourId:16, descEn:'Terracotta · City Wall', descCn:'兵马俑·古城墙'},
    {nameEn:'Xishuangbanna', nameCn:'西双版纳 · 雨林', emoji:'🌺', tourId:17, descEn:'Rainforest · Elephants', descCn:'野象谷·傣族园'},
    {nameEn:'Wuzhen Water Town', nameCn:'乌镇 · 梦里水乡', emoji:'🏘️', tourId:18, descEn:'Canals · Gondola', descCn:'西栅·摇橹船'},
    {nameEn:'Forbidden City', nameCn:'故宫 · 紫禁城', emoji:'🏰', tourId:19, descEn:'Palace · Garden', descCn:'三大殿·御花园'},
    {nameEn:'Bangkok Thailand', nameCn:'泰国 · 曼谷', emoji:'🇹🇭', tourId:1, descEn:'Grand Palace · Cabaret', descCn:'大皇宫·人妖秀'},
    {nameEn:'Maldives', nameCn:'马尔代夫 · 双鱼岛', emoji:'🇲🇻', tourId:2, descEn:'Diving · Sunset', descCn:'潜水·海上日落'},
    {nameEn:'Japan Mt.Fuji', nameCn:'日本 · 富士山', emoji:'🇯🇵', tourId:4, descEn:'Hot Spring · Cherry', descCn:'温泉·樱花'},
    {nameEn:'Bali Island', nameCn:'巴厘岛 · 蜜月', emoji:'🇮🇩', tourId:6, descEn:'Beach · SPA', descCn:'海滩·SPA'},
    {nameEn:'Turkey', nameCn:'土耳其 · 热气球', emoji:'🇹🇷', tourId:8, descEn:'Balloon · Pamukkale', descCn:'棉花堡·卡帕'},
    {nameEn:'Paris France', nameCn:'法国 · 浪漫巴黎', emoji:'🇫🇷', tourId:5, descEn:'Eiffel · Louvre', descCn:'铁塔·卢浮宫'},
  ]; %>
  <% destinations.forEach(function(d) { %>
    <a href="/tour/<%= d.tourId %><%= isEn ? '?lang=en' : '' %>" class="dest-card">
      <span class="emoji"><%= d.emoji %></span>
      <div class="name"><%= isEn ? d.nameEn : d.nameCn %></div>
      <div class="tags"><%= isEn ? d.descEn : d.descCn %></div>
    </a>
  <% }) %>
</div>

<!-- Floating buttons -->
<button class="float-btn float-top" id="backTop" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑</button>
<a href="/kefu" class="float-btn float-kefu" title="<%= isEn ? 'Customer Service' : '在线客服' %>">💬</a>

<script>
  var swiper = new Swiper('.swiper-container', {
    pagination: { el: '.swiper-pagination', clickable: true },
    loop: true, autoplay: { delay: 3500, disableOnInteraction: false },
    effect: 'fade', fadeEffect: { crossFade: true }
  });

  window.addEventListener('scroll', function() {
    var btn = document.getElementById('backTop');
    if (btn) btn.style.display = window.scrollY > 500 ? 'flex' : 'none';
  });

  function goSearch() {
    var q = document.getElementById('searchInput').value.trim();
    if (!q) { document.getElementById('searchInput').focus(); return false; }
    var lang = '<%= lang %>' === 'en' ? '?lang=en' : '';
    window.location.href = '/search?q=' + encodeURIComponent(q) + lang;
    return false;
  }

  document.getElementById('searchInput').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') { e.preventDefault(); goSearch(); }
  });
</script>

<%- include('partials/footer') %>
