<!-- Floating buttons -->
<button class="float-btn float-top" id="backTop" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑</button>
<a href="/kefu" class="float-btn float-kefu" title="<%= isEn ? 'Customer Service' : '在线客服' %>">💬</a>

<script>
  // Swiper
  var swiper = new Swiper('.swiper-container', {
    pagination:{el:'.swiper-pagination',clickable:true},
    loop:true, autoplay:{delay:3500,disableOnInteraction:false},
    effect:'fade', fadeEffect:{crossFade:true}
  });

  // Scroll-to-top button
  window.addEventListener('scroll', function(){
    var btn = document.getElementById('backTop');
    if(btn) btn.style.display = window.scrollY > 500 ? 'flex' : 'none';
  });

  // Search
  function goSearch(){
    var q = document.getElementById('searchInput').value.trim();
    if(!q){ document.getElementById('searchInput').focus(); return false; }
    var lang = '<%= lang %>' === 'en' ? '?lang=en' : '';
    window.location.href = '/search?q=' + encodeURIComponent(q) + lang;
    return false;
  }
  document.getElementById('searchInput').addEventListener('keydown', function(e){
    if(e.key === 'Enter'){ e.preventDefault(); goSearch(); }
  });

  // === Hero chips: toggle interest ===
  var heroChips = document.querySelectorAll('.hero-chip');
  var selectedHeroChips = [];
  <%
    var savedChips = (typeof userInterests !== 'undefined' ? userInterests : []);
    savedChips.forEach(function(k) { %>selectedHeroChips.push('<%= k %>');<% });
  %>
  function toggleHeroChip(el){
    var key = el.getAttribute('data-key');
    var idx = selectedHeroChips.indexOf(key);
    if(idx >= 0){ selectedHeroChips.splice(idx,1); el.classList.remove('active'); }
    else { selectedHeroChips.push(key); el.classList.add('active'); }
    // Auto-save to server
    fetch('/api/preferences', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body:JSON.stringify({interests:selectedHeroChips})
    }).catch(function(){});
  }

  // Nearby location
  function enableNearby(){
    if(!navigator.geolocation){ alert('<%= isEn ? "Geolocation not supported" : "您的浏览器不支持定位功能" %>'); return; }
    navigator.geolocation.getCurrentPosition(function(pos){
      fetch('/api/user/location', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body:JSON.stringify({latitude:pos.coords.latitude, longitude:pos.coords.longitude})
      }).then(function(r){ return r.json(); }).then(function(d){ if(d.success) window.location.reload(); });
    }, function(){
      alert('<%= isEn ? "Please allow location access" : "请在浏览器设置中允许获取位置信息" %>');
    }, {enableHighAccuracy:true, timeout:8000});
  }

  // Smooth scroll for section nav links
  document.querySelectorAll('.sec-nav a[href^="#"]').forEach(function(a){
    a.addEventListener('click', function(e){
      e.preventDefault();
      var target = document.querySelector(this.getAttribute('href'));
      if(target) target.scrollIntoView({behavior:'smooth', block:'start'});
    });
  });
</script>

