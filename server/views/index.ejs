<% let path='/'; let title=__('site.title.home'); %>
<%- include('partials/header', { path, title }) %>

<style>
/* === Global === */
body { background:#fafbfc; }
:root {
  --green: #59b200; --orange: #ff6600; --blue: #1a73e8; --dark: #1a2332;
  --radius: 14px; --radius-sm: 10px; --shadow: 0 2px 16px rgba(0,0,0,0.06);
  --shadow-hover: 0 12px 40px rgba(0,0,0,0.10);
}

/* === Hero === */
.hero-section {
  position:relative; width:100%; height:78vh; min-height:480px; max-height:680px; overflow:hidden;
  margin-bottom:0;
}
.hero-section .swiper-slide img {
  width:100%; height:100%; object-fit:cover; filter:brightness(0.6) saturate(1.1);
  transition: transform 8s ease;
}
.swiper-slide-active img { transform:scale(1.05); }
.hero-overlay {
  position:absolute; inset:0;
  background: linear-gradient(135deg, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.15) 50%, rgba(0,0,0,0.3) 100%);
  z-index:2; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:20px;
}
.hero-overlay h1 {
  color:#fff; font-size:clamp(28px,5vw,52px); font-weight:800; text-shadow:0 4px 30px rgba(0,0,0,0.4);
  margin-bottom:8px; text-align:center; letter-spacing:-0.5px;
}
.hero-overlay p {
  color:rgba(255,255,255,0.85); font-size:clamp(14px,1.6vw,18px); margin-bottom:28px; text-align:center;
}
.hero-search {
  display:flex; max-width:580px; width:90%;
  background:rgba(255,255,255,0.96); border-radius:50px; overflow:hidden;
  box-shadow:0 8px 40px rgba(0,0,0,0.18); transition:0.3s;
}
.hero-search:focus-within { box-shadow:0 8px 50px rgba(0,0,0,0.28); transform:scale(1.01); }
.hero-search input {
  flex:1; border:none; padding:15px 24px; font-size:15px; outline:none; background:transparent;
}
.hero-search button {
  padding:15px 32px; background:linear-gradient(135deg,#ff6600,#ff4500);
  color:#fff; border:none; font-size:15px; font-weight:700; cursor:pointer; transition:0.3s;
}
.hero-search button:hover { opacity:0.9; }

/* Quick interest chips in hero */
.hero-chips {
  display:flex; gap:8px; flex-wrap:wrap; justify-content:center; margin-top:20px; max-width:600px;
}
.hero-chip {
  padding:6px 16px; border-radius:20px; font-size:13px; cursor:pointer;
  background:rgba(255,255,255,0.15); color:rgba(255,255,255,0.9);
  border:1px solid rgba(255,255,255,0.2); transition:all 0.25s; user-select:none;
}
.hero-chip:hover { background:rgba(255,255,255,0.25); border-color:rgba(255,255,255,0.4); }
.hero-chip.active { background:#fff; color:var(--orange); border-color:#fff; font-weight:600; }

/* === Section Titles (compact) === */
.sec-title {
  text-align:center; padding:35px 15px 6px; position:relative;
}
.sec-title .label {
  display:inline-flex; align-items:center; gap:8px; font-size:26px; font-weight:700; color:var(--dark);
  margin:0;
}
.sec-title .label .bar {
  display:inline-block; width:8px; height:28px; border-radius:4px;
  background:linear-gradient(180deg,var(--green),var(--orange));
}
.sec-title .sub { color:#94a3b8; font-size:14px; margin:6px 0 0; }

/* === Quick Section Nav === */
.sec-nav {
  display:flex; justify-content:center; gap:6px; flex-wrap:wrap;
  padding:8px 15px 4px; max-width:900px; margin:0 auto;
}
.sec-nav a {
  padding:7px 18px; border-radius:20px; font-size:13px; font-weight:500;
  text-decoration:none; color:#64748b; background:#fff; border:1px solid #e2e8f0;
  transition:all 0.2s; display:flex; align-items:center; gap:5px;
}
.sec-nav a:hover { border-color:var(--green); color:var(--green); background:#f0fdf4; }

/* === Stats Bar (icon-driven) === */
.stats-bar {
  display:flex; justify-content:center; gap:40px; padding:28px 15px;
  background:#fff; border-bottom:1px solid #f1f5f9; flex-wrap:wrap;
}
.stats-bar .stat-item { text-align:center; min-width:100px; }
.stats-bar .stat-item .icon { font-size:28px; display:block; margin-bottom:4px; }
.stats-bar .stat-item .num { font-size:28px; font-weight:800; color:var(--green); line-height:1.2; }
.stats-bar .stat-item .label { font-size:12px; color:#94a3b8; margin-top:2px; }

/* === Tour Grid — Card v2 === */
.tour-grid {
  display:grid; grid-template-columns:repeat(auto-fill,minmax(310px,1fr)); gap:22px;
  max-width:1400px; margin:0 auto; padding:14px 15px 6px;
}
.tour-card {
  background:#fff; border-radius:var(--radius); overflow:hidden;
  box-shadow:var(--shadow); transition:all 0.35s cubic-bezier(.4,0,.2,1);
  border:1px solid #f0f0f0; display:flex; flex-direction:column; height:100%;
}
.tour-card:hover {
  transform:translateY(-5px); box-shadow:var(--shadow-hover);
}
.tour-card .card-img {
  position:relative; height:200px; overflow:hidden; flex-shrink:0;
}
.tour-card .card-img img {
  width:100%; height:100%; object-fit:cover; transition:transform 0.6s;
}
.tour-card:hover .card-img img { transform:scale(1.08); }
.tour-card .card-img .tag {
  position:absolute; top:10px; left:0; background:var(--green); color:#fff;
  padding:3px 12px; font-size:11px; font-weight:600; border-radius:0 4px 4px 0;
}
.tour-card .card-img .tag-promo {
  position:absolute; top:10px; right:10px; background:var(--orange); color:#fff;
  padding:2px 10px; font-size:11px; font-weight:600; border-radius:4px;
  box-shadow:0 2px 8px rgba(255,102,0,0.3);
}
.tour-card .card-img .badge-overlay {
  position:absolute; bottom:10px; left:10px; right:10px;
  display:flex; gap:6px; flex-wrap:wrap;
}
.tour-card .card-img .badge-overlay span {
  background:rgba(0,0,0,0.55); color:#fff; padding:2px 10px; border-radius:12px;
  font-size:11px; font-weight:500; backdrop-filter:blur(4px);
}
.tour-card .card-body { padding:16px 18px; flex:1; display:flex; flex-direction:column; }
.tour-card .card-body h3 {
  font-size:15px; color:var(--dark); margin:0 0 6px; font-weight:600;
  overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
}
.tour-card .card-body .desc {
  color:#94a3b8; font-size:13px; line-height:1.5; margin:0 0 10px; flex:1;
  display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;
}
.tour-card .card-body .meta {
  display:flex; justify-content:space-between; align-items:center;
  padding-top:12px; border-top:1px solid #f1f5f9; margin-top:auto;
}
.tour-card .card-body .meta .price { color:var(--orange); font-size:13px; font-weight:600; }
.tour-card .card-body .meta .price b { font-size:20px; }
.tour-card .card-body .meta .rating { color:#94a3b8; font-size:12px; }

/* === Featured card (first 3 in hot section) === */
.tour-card.featured { grid-column:span 1; }
.tour-card.featured .card-img { height:240px; }
@media (min-width:1100px) {
  .tour-card.featured:first-child { grid-column:span 2; }
  .tour-card.featured:first-child .card-img { height:280px; }
}

/* === Promo ribbon === */
.promo-wrap {
  background:linear-gradient(135deg,#fff8f0 0%,#fff0e0 100%);
  padding:6px 0 28px; margin-top:10px;
}

/* === Destination chips (replaces old grid) === */
.dest-chips {
  display:flex; flex-wrap:wrap; justify-content:center; gap:10px;
  max-width:1300px; margin:12px auto 10px; padding:0 15px;
}
.dest-chip {
  display:flex; align-items:center; gap:6px; padding:8px 16px;
  background:#fff; border:1px solid #e2e8f0; border-radius:30px;
  text-decoration:none; transition:all 0.2s; font-size:13px; color:var(--dark);
  box-shadow:0 1px 4px rgba(0,0,0,0.03);
}
.dest-chip:hover {
  border-color:var(--green); background:#f0fdf4; transform:translateY(-2px);
  box-shadow:0 6px 20px rgba(89,178,0,0.12);
}
.dest-chip .emoji { font-size:18px; }
.dest-chip .name { font-weight:500; }
.dest-chip .sub { color:#94a3b8; font-size:11px; }

/* === CTA Banner === */
.cta-banner {
  max-width:1350px; margin:24px auto; padding:0 15px;
}
.cta-inner {
  background:linear-gradient(135deg,#1a2332 0%,#2d3a4a 100%);
  border-radius:20px; padding:32px 40px; display:flex;
  justify-content:space-between; align-items:center; flex-wrap:wrap; gap:20px;
  box-shadow:0 10px 35px rgba(26,35,50,0.2); position:relative; overflow:hidden;
}
.cta-inner::before {
  content:''; position:absolute; top:-50%; right:-30%; width:300px; height:300px;
  background:radial-gradient(circle,rgba(89,178,0,0.1),transparent);
  border-radius:50%;
}
.cta-text h3 { font-size:18px; font-weight:700; color:#fff; margin:0 0 4px; }
.cta-text p { font-size:13px; color:rgba(255,255,255,0.7); margin:0; }
.cta-phone { text-align:right; }
.cta-phone .num { font-size:20px; font-weight:700; color:var(--orange); }
.cta-phone .hours { font-size:11px; color:rgba(255,255,255,0.5); }
.cta-btn {
  background:linear-gradient(135deg,var(--orange),#ff4500); color:#fff; padding:10px 26px;
  border-radius:30px; font-size:14px; font-weight:700; text-decoration:none; transition:0.3s;
  box-shadow:0 4px 15px rgba(255,102,0,0.3);
}
.cta-btn:hover { transform:scale(1.04); }

/* === Floating === */
.float-btn {
  position:fixed; width:44px; height:44px; right:20px; z-index:999;
  border-radius:50%; display:flex; align-items:center; justify-content:center;
  text-decoration:none; border:none; cursor:pointer; color:#fff; font-size:18px;
  box-shadow:0 4px 15px rgba(0,0,0,0.2); transition:all 0.3s;
}
.float-btn:hover { transform:translateY(-3px); }
.float-top { bottom:28px; background:var(--dark); display:none; }
.float-kefu { bottom:82px; background:linear-gradient(135deg,var(--orange),#ff4500); }

/* === Nearby === */
.nearby-bar {
  display:flex; justify-content:center; gap:12px; flex-wrap:wrap;
  padding:18px 15px; max-width:1400px; margin:0 auto;
}
.nearby-btn {
  display:inline-flex; align-items:center; gap:6px;
  padding:10px 24px; background:var(--blue); color:#fff;
  border:none; border-radius:30px; font-size:14px; font-weight:600; cursor:pointer;
  transition:0.3s; box-shadow:0 4px 15px rgba(26,115,232,0.25);
}
.nearby-btn:hover { transform:translateY(-2px); opacity:0.92; }
.nearby-link { color:var(--blue); font-size:13px; text-decoration:none; display:inline-flex; align-items:center; gap:4px; }

/* === Responsive === */
@media (max-width:768px) {
  .hero-section { height:60vh; min-height:420px; }
  .hero-overlay h1 { font-size:26px; }
  .hero-search input { padding:12px 16px; font-size:14px; }
  .hero-search button { padding:12px 20px; font-size:14px; }
  .hero-chips { gap:6px; }
  .hero-chip { padding:4px 12px; font-size:12px; }
  .tour-grid { grid-template-columns:1fr; gap:16px; }
  .tour-card.featured:first-child .card-img { height:220px; }
  .sec-title .label { font-size:20px; }
  .stats-bar { gap:16px; padding:20px 10px; }
  .stats-bar .stat-item { min-width:70px; }
  .stats-bar .stat-item .num { font-size:22px; }
  .cta-inner { flex-direction:column; text-align:center; padding:24px 20px; }
  .cta-phone { text-align:center; }
  .dest-chips { gap:8px; }
  .dest-chip { font-size:12px; padding:6px 12px; }
  .sec-nav { gap:4px; }
  .sec-nav a { font-size:12px; padding:5px 12px; }
}
</style>

<!-- ========== HERO ========== -->
<div class="hero-section">
  <div class="swiper-container" style="width:100%;height:100%;">
    <div class="swiper-wrapper">
      <div class="swiper-slide"><img src="/img/search.jpg" alt="旅游推荐"></div>
      <div class="swiper-slide"><img src="/img/t10.jpg" alt="黄山"></div>
      <div class="swiper-slide"><img src="/img/t11.jpg" alt="九寨沟"></div>
    </div>
    <div class="swiper-pagination"></div>
  </div>
  <div class="hero-overlay">
    <h1><%= __('home.hero.title') %></h1>
    <p><%= __('home.hero.subtitle') %></p>
    <form class="hero-search" action="/search<%= isEn ? '?lang=en' : '' %>" method="GET" onsubmit="return goSearch()">
      <input type="text" name="q" id="searchInput" placeholder="🔍 <%= __('home.hero.search') %>" autocomplete="off">
      <button type="submit"><%= __('home.hero.searchBtn') %></button>
    </form>
    <!-- Quick interest tags in hero -->
    <div class="hero-chips">
      <% var chipList = [
        {key:'自然风光', en:'Nature', cn:'🏔️ 自然风光'},
        {key:'海岛度假', en:'Beach', cn:'🏝️ 海岛度假'},
        {key:'历史文化', en:'History', cn:'🏛️ 文化'},
        {key:'美食之旅', en:'Food', cn:'🍜 美食'},
        {key:'亲子游', en:'Family', cn:'👨‍👩‍👧 亲子'},
        {key:'蜜月旅行', en:'Honeymoon', cn:'💑 蜜月'},
      ]; %>
      <% chipList.forEach(function(c) { %>
        <span class="hero-chip <%= (typeof userInterests !== 'undefined' && userInterests.indexOf(c.key) >= 0) ? 'active' : '' %>"
              data-key="<%= c.key %>" onclick="toggleHeroChip(this)">
          <%= isEn ? c.en : c.cn %>
        </span>
      <% }) %>
    </div>
  </div>
</div>

<!-- ========== STATS ========== -->
<div class="stats-bar">
  <div class="stat-item"><span class="icon">🏝️</span><div class="num">40</div><div class="label"><%= isEn ? 'Tours' : '精选线路' %></div></div>
  <div class="stat-item"><span class="icon">📍</span><div class="num">32</div><div class="label"><%= isEn ? 'Destinations' : '热门目的地' %></div></div>
  <div class="stat-item"><span class="icon">⭐</span><div class="num">96%</div><div class="label"><%= isEn ? 'Satisfaction' : '满意度' %></div></div>
  <div class="stat-item"><span class="icon">💬</span><div class="num">24h</div><div class="label"><%= isEn ? 'Online' : '客服在线' %></div></div>
  <div class="stat-item"><span class="icon">💰</span><div class="num"><%= (typeof bookingCount !== 'undefined' ? (bookingCount * 2500).toFixed(0) : '9999+') %></div><div class="label"><%= isEn ? 'Served' : '服务人次' %></div></div>
</div>

<!-- ========== QUICK NAV ========== -->
<div class="sec-nav">
  <a href="#sec-hot">🔥 <%= isEn ? 'Hot' : '热门线路' %></a>
  <a href="#sec-promo">💰 <%= isEn ? 'Deals' : '限时特惠' %></a>
  <% if (recommendTours && recommendTours.length > 0) { %><a href="#sec-recommend">🎯 <%= isEn ? 'For You' : '为你推荐' %></a><% } %>
  <a href="#sec-nearby">📍 <%= isEn ? 'Nearby' : '周边游' %></a>
  <a href="#sec-dest">🌍 <%= isEn ? 'Destinations' : '目的地' %></a>
  <a href="/nearby" style="border-color:var(--blue);color:var(--blue);">📍 <%= isEn ? 'All Nearby' : '完整周边' %></a>
</div>

<!-- ========== HOT TOURS ========== -->
<div class="sec-title" id="sec-hot">
  <h2 class="label"><span class="bar"></span>🏝️ <%= __('home.hotTours') %></h2>
  <p class="sub"><%= __('home.hotToursDesc') %></p>
</div>

<div class="tour-grid">
  <% hotTours.forEach(function(tour, idx) { %>
    <a href="/tour/<%= tour.id %><%= isEn ? '?lang=en' : '' %>" style="text-decoration:none;color:inherit;">
      <div class="tour-card <%= idx < 3 ? 'featured' : '' %>">
        <div class="card-img">
          <img src="/img/<%= tour.image %>" alt="<%= tt(tour, 'title') %>">
          <span class="tag"><%= tt(tour, 'type_label') %></span>
          <% if (tour.is_promotion) { %><span class="tag-promo"><%= isEn ? 'SALE' : '特价' %></span><% } %>
          <div class="badge-overlay">
            <% if (tour.days) { %><span>🗓️ <%= tour.days %></span><% } %>
            <% if (tour.satisfaction) { %><span>⭐ <%= tour.satisfaction %></span><% } %>
          </div>
        </div>
        <div class="card-body">
          <h3><%= tt(tour, 'title') %></h3>
          <p class="desc"><%= tt(tour, 'description') %></p>
          <div class="meta">
            <span class="price">¥&nbsp;<b><%= tour.price %></b><%= isEn ? " from" : "起" %>
              <% if (tour.original_price > tour.price) { %>
                <span style="font-size:11px;text-decoration:line-through;color:#bbb;font-weight:normal;">¥<%= tour.original_price %></span>
              <% } %>
            </span>
            <span class="rating">🔥 <%= (idx + 1) %></span>
          </div>
        </div>
      </div>
    </a>
  <% }) %>
</div>

<!-- ========== PROMOTIONS ========== -->
<div class="promo-wrap" id="sec-promo">
<div class="sec-title">
  <h2 class="label"><span class="bar"></span>🔥 <%= __('home.promotions') %></h2>
  <p class="sub"><%= __('home.promotionsDesc') %></p>
</div>
<div class="tour-grid">
  <% hotTours.filter(t => t.is_promotion).slice(0, 4).forEach(function(tour) { %>
    <a href="/tour/<%= tour.id %><%= isEn ? '?lang=en' : '' %>" style="text-decoration:none;color:inherit;">
      <div class="tour-card" style="border-top:3px solid var(--orange);">
        <div class="card-img">
          <img src="/img/<%= tour.image %>" alt="<%= tt(tour, 'title') %>">
          <span class="tag"><%= tt(tour, 'type_label') %></span>
          <span class="tag-promo"><%= isEn ? '🔥 SALE' : '🔥 特价' %></span>
          <div class="badge-overlay">
            <span>💰 <%- isEn ? 'Save' : '省' %> ¥<%= (tour.original_price - tour.price).toFixed(0) %></span>
          </div>
        </div>
        <div class="card-body">
          <h3><%= tt(tour, 'title') %></h3>
          <p class="desc"><%= tt(tour, 'description') %></p>
          <div class="meta">
            <span class="price">¥&nbsp;<b><%= tour.price %></b><%= isEn ? " from" : "起" %>
              <span style="font-size:11px;text-decoration:line-through;color:#bbb;">¥<%= tour.original_price %></span>
            </span>
            <span class="rating">⏰ <%= tour.promotion_end ? tour.promotion_end.slice(0,7) : (isEn ? 'Limited' : '限时') %></span>
          </div>
        </div>
      </div>
    </a>
  <% }) %>
</div>
</div>

<!-- ========== PERSONALIZED RECOMMENDATIONS ========== -->
<% if (typeof recommendTours !== 'undefined' && recommendTours.length > 0) { %>
<div class="sec-title" id="sec-recommend">
  <h2 class="label"><span class="bar"></span>🎯 <%= isEn ? 'Recommended for You' : '为你推荐' %></h2>
  <p class="sub"><%= isEn ? 'Based on your browsing and interests' : '基于你的浏览和兴趣偏好' %></p>
</div>
<div class="tour-grid">
  <% recommendTours.slice(0, 6).forEach(function(tour) { %>
    <a href="/tour/<%= tour.id %><%= isEn ? '?lang=en' : '' %>" style="text-decoration:none;color:inherit;">
      <div class="tour-card" style="border-left:3px solid var(--orange);">
        <div class="card-img">
          <img src="/img/<%= tour.image %>" alt="<%= tt(tour, 'title') %>">
          <span class="tag"><%= tt(tour, 'type_label') %></span>
          <div class="badge-overlay">
            <span><%= typeof recommendReasons !== 'undefined' && recommendReasons[tour.id] ? recommendReasons[tour.id] : '🎯 猜你喜欢' %></span>
          </div>
        </div>
        <div class="card-body">
          <h3><%= tt(tour, 'title') %></h3>
          <p class="desc"><%= tt(tour, 'description') %></p>
          <div class="meta">
            <span class="price">¥&nbsp;<b><%= tour.price %></b><%= isEn ? " from" : "起" %></span>
            <span class="rating">⭐ <%= tour.satisfaction %></span>
          </div>
        </div>
      </div>
    </a>
  <% }) %>
</div>
<% } %>

<!-- ========== NEARBY TOURS ========== -->
<div class="sec-title" id="sec-nearby">
  <h2 class="label"><span class="bar"></span>📍 <%= isEn ? 'Nearby Tours' : '附近旅游' %></h2>
  <p class="sub"><%= isEn ? 'Discover tours near your location' : '发现身边最近的旅游好去处' %></p>
</div>

<% if (typeof nearbyTours !== 'undefined' && nearbyTours.length > 0) { %>
<div class="tour-grid" style="padding-bottom:4px;">
  <% nearbyTours.forEach(function(tour) { %>
    <a href="/tour/<%= tour.id %><%= isEn ? '?lang=en' : '' %>" style="text-decoration:none;color:inherit;">
      <div class="tour-card" style="border-left:3px solid var(--blue);">
        <div class="card-img">
          <img src="/img/<%= tour.image %>" alt="<%= tt(tour, 'title') %>">
          <span class="tag"><%= tt(tour, 'type_label') %></span>
          <div class="badge-overlay">
            <span>📍 <%= tour.city %></span>
            <span>📏 <%= tour.distance %>km</span>
          </div>
        </div>
        <div class="card-body">
          <h3><%= tt(tour, 'title') %></h3>
          <p class="desc"><%= tt(tour, 'description') %></p>
          <div class="meta">
            <span class="price">¥&nbsp;<b><%= tour.price %></b><%= isEn ? " from" : "起" %></span>
            <span class="rating">⭐ <%= tour.satisfaction %></span>
          </div>
        </div>
      </div>
    </a>
  <% }) %>
</div>
<div class="nearby-bar" style="padding-top:4px;">
