<% let path='/'; let title=__('site.title.home'); %>
<%- include('partials/header', { path, title }) %>

<style>
/* === Scroll Progress === */
#scrollProgress {
  position:fixed; top:0; left:0; height:3px; background:linear-gradient(90deg,var(--green),var(--orange));
  z-index:9999; width:0%; transition:width 0.1s;
}

/* === Global === */
body { background:#fafbfc; }
:root {
  --green: #59b200; --orange: #ff6600; --blue: #1a73e8; --dark: #1a2332;
  --radius: 14px; --radius-sm: 10px; --shadow: 0 2px 16px rgba(0,0,0,0.06);
  --shadow-hover: 0 12px 40px rgba(0,0,0,0.10);
}

/* Card entrance animation */
.tour-card { animation:fadeUp 0.5s ease both; }
@keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
.tour-card:nth-child(1) { animation-delay:0s; }
.tour-card:nth-child(2) { animation-delay:0.05s; }
.tour-card:nth-child(3) { animation-delay:0.1s; }
.tour-card:nth-child(4) { animation-delay:0.15s; }
.tour-card:nth-child(5) { animation-delay:0.2s; }
.tour-card:nth-child(6) { animation-delay:0.25s; }
.tour-card:nth-child(7) { animation-delay:0.3s; }
.tour-card:nth-child(8) { animation-delay:0.35s; }
.tour-card:nth-child(9) { animation-delay:0.4s; }

/* === Hero === */
.hero-section {
  position:relative; width:100%; height:72vh; min-height:460px; max-height:640px; overflow:hidden;
  margin-bottom:0;
}
.hero-section::after {
  content:''; position:absolute; inset:0; z-index:1;
  background: repeating-linear-gradient(45deg, transparent, transparent 40px, rgba(255,255,255,0.02) 40px, rgba(255,255,255,0.02) 80px);
}
.hero-section .swiper-slide img {
  width:100%; height:100%; object-fit:cover; filter:brightness(0.6) saturate(1.1);
  transition: transform 8s ease;
}
.swiper-slide-active img { transform:scale(1.05); }
.hero-overlay {
  position:absolute; inset:0; z-index:3;
  background: linear-gradient(135deg, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.1) 50%, rgba(0,0,0,0.3) 100%);
  display:flex; flex-direction:column; align-items:center; justify-content:center; padding:20px;
}
.hero-overlay h1 {
  color:#fff; font-size:clamp(26px,4.5vw,48px); font-weight:800; text-shadow:0 4px 30px rgba(0,0,0,0.4);
  margin-bottom:6px; text-align:center; letter-spacing:-0.5px;
}
.hero-overlay p {
  color:rgba(255,255,255,0.85); font-size:clamp(14px,1.4vw,17px); margin-bottom:24px; text-align:center;
}
.hero-search {
  display:flex; max-width:540px; width:90%;
  background:rgba(255,255,255,0.96); border-radius:50px; overflow:hidden;
  box-shadow:0 8px 40px rgba(0,0,0,0.18); transition:0.3s;
}
.hero-search:focus-within { box-shadow:0 8px 50px rgba(0,0,0,0.28); transform:scale(1.01); }
.hero-search input {
  flex:1; border:none; padding:14px 22px; font-size:15px; outline:none; background:transparent;
}
.hero-search button {
  padding:14px 28px; background:linear-gradient(135deg,#ff6600,#ff4500);
  color:#fff; border:none; font-size:14px; font-weight:700; cursor:pointer; transition:0.3s;
}
.hero-search button:hover { opacity:0.9; }

/* Quick interest chips in hero */
.hero-chips {
  display:flex; gap:6px; flex-wrap:wrap; justify-content:center; margin-top:16px; max-width:500px;
}
.hero-chip {
  padding:5px 14px; border-radius:20px; font-size:12px; cursor:pointer;
  background:rgba(255,255,255,0.12); color:rgba(255,255,255,0.85);
  border:1px solid rgba(255,255,255,0.15); transition:all 0.25s; user-select:none;
}
.hero-chip:hover { background:rgba(255,255,255,0.22); border-color:rgba(255,255,255,0.35); }
.hero-chip.active { background:#fff; color:var(--orange); border-color:#fff; font-weight:600; }

/* === Section Titles (compact) === */
.sec-title {
  text-align:center; padding:30px 15px 4px; position:relative;
}
.sec-title .label {
  display:inline-flex; align-items:center; gap:8px; font-size:24px; font-weight:700; color:var(--dark);
  margin:0;
}
.sec-title .label .bar {
  display:inline-block; width:6px; height:24px; border-radius:3px;
  background:linear-gradient(180deg,var(--green),var(--orange));
}
.sec-title .sub { color:#94a3b8; font-size:13px; margin:5px 0 0; }

/* === Quick Section Nav (sticky) === */
.sec-nav-wrap {
  position:sticky; top:0; z-index:50; background:rgba(255,255,255,0.92);
  backdrop-filter:blur(8px); border-bottom:1px solid #f1f5f9; padding:6px 0;
}
.sec-nav {
  display:flex; justify-content:center; gap:5px; flex-wrap:wrap;
  max-width:900px; margin:0 auto; padding:0 15px;
}
.sec-nav a {
  padding:6px 16px; border-radius:20px; font-size:12px; font-weight:500;
  text-decoration:none; color:#64748b; background:transparent; border:1px solid #e2e8f0;
  transition:all 0.2s; display:flex; align-items:center; gap:4px;
}
.sec-nav a:hover { border-color:var(--green); color:var(--green); background:#f0fdf4; }

/* === Stats Bar === */
.stats-bar {
  display:flex; justify-content:center; gap:30px; padding:22px 15px;
  background:#fff; border-bottom:1px solid #f1f5f9; flex-wrap:wrap;
}
.stats-bar .stat-item { text-align:center; min-width:80px; }
.stats-bar .stat-item .icon { font-size:24px; display:block; margin-bottom:2px; }
.stats-bar .stat-item .num { font-size:24px; font-weight:800; color:var(--green); line-height:1.2; }
.stats-bar .stat-item .label { font-size:11px; color:#94a3b8; margin-top:2px; }

/* === Tour Grid === */
.tour-grid {
  display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:20px;
  max-width:1400px; margin:0 auto; padding:12px 15px 4px;
}
.tour-card {
  background:#fff; border-radius:var(--radius); overflow:hidden;
  box-shadow:var(--shadow); transition:all 0.35s cubic-bezier(.4,0,.2,1);
  border:1px solid #f0f0f0; display:flex; flex-direction:column; height:100%;
}
.tour-card:hover {
  transform:translateY(-4px); box-shadow:0 8px 30px rgba(0,0,0,0.08), 0 0 0 1px rgba(89,178,0,0.1);
}
.tour-card .card-img {
  position:relative; height:190px; overflow:hidden; flex-shrink:0;
}
.tour-card .card-img img {
  width:100%; height:100%; object-fit:cover; transition:transform 0.6s;
}
.tour-card:hover .card-img img { transform:scale(1.08); }
.tour-card .card-img .tag {
  position:absolute; top:10px; left:0; background:var(--green); color:#fff;
  padding:3px 10px; font-size:11px; font-weight:600; border-radius:0 4px 4px 0;
}
.tour-card .card-img .tag-promo {
  position:absolute; top:10px; right:10px; background:var(--orange); color:#fff;
  padding:2px 8px; font-size:10px; font-weight:600; border-radius:4px;
  box-shadow:0 2px 8px rgba(255,102,0,0.3);
}
.tour-card .card-img .badge-overlay {
  position:absolute; bottom:8px; left:8px; right:8px;
  display:flex; gap:5px; flex-wrap:wrap;
}
.tour-card .card-img .badge-overlay span {
  background:rgba(0,0,0,0.5); color:#fff; padding:2px 8px; border-radius:10px;
  font-size:10px; font-weight:500; backdrop-filter:blur(3px);
}
.tour-card .card-body { padding:14px 16px; flex:1; display:flex; flex-direction:column; }
.tour-card .card-body h3 {
  font-size:14px; color:var(--dark); margin:0 0 5px; font-weight:600;
  overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
}
.tour-card .card-body .desc {
  color:#94a3b8; font-size:12px; line-height:1.5; margin:0 0 8px; flex:1;
  display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;
}
.tour-card .card-body .meta {
  display:flex; justify-content:space-between; align-items:center;
  padding-top:10px; border-top:1px solid #f1f5f9; margin-top:auto;
}
.tour-card .card-body .meta .price { color:var(--orange); font-size:12px; font-weight:600; }
.tour-card .card-body .meta .price b { font-size:18px; }
.tour-card .card-body .meta .rating { color:#94a3b8; font-size:11px; }

/* === Featured card === */
.tour-card.featured .card-img { height:220px; }
@media (min-width:1100px) {
  .tour-card.featured:first-child { grid-column:span 2; }
  .tour-card.featured:first-child .card-img { height:260px; }
}

/* === Promo === */
.promo-wrap {
  background:linear-gradient(135deg,#fff8f0 0%,#fff0e0 100%);
  padding:4px 0 20px; margin-top:6px; border-radius:0;
}

/* === Dest chips === */
.dest-chips {
  display:flex; flex-wrap:wrap; justify-content:center; gap:8px;
  max-width:1200px; margin:10px auto; padding:0 15px;
}
.dest-chip {
  display:inline-flex; align-items:center; gap:4px; padding:6px 14px;
  background:#fff; border:1px solid #e2e8f0; border-radius:20px;
  text-decoration:none; transition:all 0.2s; font-size:12px; color:var(--dark);
}
.dest-chip:hover {
  border-color:var(--green); background:#f0fdf4; transform:translateY(-2px);
  box-shadow:0 4px 12px rgba(89,178,0,0.1);
}
.dest-chip .name { font-weight:500; }
.dest-chip .sub { color:#94a3b8; font-size:10px; }

/* === CTA === */
.cta-banner { max-width:1350px; margin:20px auto; padding:0 15px; }
.cta-inner {
  background:linear-gradient(135deg,#1a2332 0%,#2d3a4a 100%);
  border-radius:16px; padding:28px 36px; display:flex;
  justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px;
  box-shadow:0 8px 30px rgba(26,35,50,0.15); position:relative; overflow:hidden;
}
.cta-inner::before {
  content:''; position:absolute; top:-40%; right:-20%; width:250px; height:250px;
  background:radial-gradient(circle,rgba(89,178,0,0.08),transparent);
  border-radius:50%;
}
.cta-text h3 { font-size:17px; font-weight:700; color:#fff; margin:0 0 3px; }
.cta-text p { font-size:12px; color:rgba(255,255,255,0.65); margin:0; }
.cta-phone .num { font-size:18px; font-weight:700; color:var(--orange); }
.cta-phone .hours { font-size:11px; color:rgba(255,255,255,0.45); }
.cta-btn {
  background:linear-gradient(135deg,var(--orange),#ff4500); color:#fff; padding:9px 22px;
  border-radius:25px; font-size:13px; font-weight:700; text-decoration:none; transition:0.3s;
  box-shadow:0 4px 12px rgba(255,102,0,0.25);
}
.cta-btn:hover { transform:scale(1.04); }

/* === Float === */
.float-btn {
  position:fixed; width:40px; height:40px; right:18px; z-index:999;
  border-radius:50%; display:flex; align-items:center; justify-content:center;
  text-decoration:none; border:none; cursor:pointer; color:#fff; font-size:16px;
  box-shadow:0 3px 12px rgba(0,0,0,0.18); transition:all 0.3s;
}
.float-btn:hover { transform:translateY(-3px); }
.float-top { bottom:25px; background:var(--dark); display:none; }
.float-kefu { bottom:75px; background:linear-gradient(135deg,var(--orange),#ff4500); }

/* === Nearby === */
.nearby-bar { display:flex; justify-content:center; gap:10px; flex-wrap:wrap; padding:14px 15px; max-width:1400px; margin:0 auto; }
.nearby-btn {
  display:inline-flex; align-items:center; gap:5px;
  padding:9px 22px; background:var(--blue); color:#fff;
  border:none; border-radius:25px; font-size:13px; font-weight:600; cursor:pointer;
  transition:0.3s; box-shadow:0 3px 12px rgba(26,115,232,0.2);
}
.nearby-btn:hover { transform:translateY(-2px); }
.nearby-link { color:var(--blue); font-size:12px; text-decoration:none; display:inline-flex; align-items:center; gap:3px; }

/* === Responsive === */
@media (max-width:768px) {
  .hero-section { height:55vh; min-height:380px; }
  .hero-overlay h1 { font-size:24px; }
  .hero-search input { padding:10px 14px; font-size:13px; }
  .hero-search button { padding:10px 16px; font-size:13px; }
  .hero-chips { gap:5px; }
  .hero-chip { padding:3px 10px; font-size:11px; }
  .tour-grid { grid-template-columns:1fr; gap:14px; }
  .tour-card.featured:first-child .card-img { height:200px; }
  .sec-title .label { font-size:19px; }
  .stats-bar { gap:8px; padding:15px 8px; }
  .stats-bar .stat-item { min-width:60px; }
  .stats-bar .stat-item .num { font-size:18px; }
  .stats-bar .stat-item .label { font-size:10px; }
  .cta-inner { flex-direction:column; text-align:center; padding:20px; }
  .cta-phone { text-align:center; }
  .dest-chips { gap:6px; }
  .dest-chip { font-size:11px; padding:5px 10px; }
  .sec-nav-wrap { position:relative; }
  .sec-nav a { font-size:11px; padding:4px 10px; }
}
</style>

<!-- ========== SCROLL PROGRESS ========== -->
<div id="scrollProgress"></div>

<!-- ========== HERO ========== -->
<div class="hero-section">
  <div class="swiper-container" style="width:100%;height:100%;">
    <div class="swiper-wrapper">
      <div class="swiper-slide"><img src="/img/search.jpg" alt="旅游推荐"></div>
      <div class="swiper-slide"><img src="/img/t10.jpg" alt="黄山"></div>
      <div class="swiper-slide"><img src="/img/t11.jpg" alt="九寨沟"></div>
    </div>
    <div class="swiper-pagination"></div>
  </div>
  <div class="hero-overlay">
    <h1><%= __('home.hero.title') %></h1>
    <p><%= __('home.hero.subtitle') %></p>
    <form class="hero-search" action="/search<%= isEn ? '?lang=en' : '' %>" method="GET" onsubmit="return goSearch()">
      <input type="text" name="q" id="searchInput" placeholder="🔍 <%= __('home.hero.search') %>" autocomplete="off">
      <button type="submit"><%= __('home.hero.searchBtn') %></button>
    </form>
    <!-- Quick interest tags in hero -->
    <div class="hero-chips">
      <% var chipList = [
        {key:'自然风光', en:'Nature', cn:'🏔️ 自然风光'},
        {key:'海岛度假', en:'Beach', cn:'🏝️ 海岛度假'},
        {key:'历史文化', en:'History', cn:'🏛️ 文化'},
        {key:'美食之旅', en:'Food', cn:'🍜 美食'},
        {key:'亲子游', en:'Family', cn:'👨‍👩‍👧 亲子'},
        {key:'蜜月旅行', en:'Honeymoon', cn:'💑 蜜月'},
      ]; %>
      <% chipList.forEach(function(c) { %>
        <span class="hero-chip <%= (typeof userInterests !== 'undefined' && userInterests.indexOf(c.key) >= 0) ? 'active' : '' %>"
              data-key="<%= c.key %>" onclick="toggleHeroChip(this)">
          <%= isEn ? c.en : c.cn %>
        </span>
      <% }) %>
    </div>
  </div>
</div>

<!-- ========== STATS ========== -->
<div class="stats-bar">
  <div class="stat-item"><span class="icon">🏝️</span><div class="num">40</div><div class="label"><%= isEn ? 'Tours' : '精选线路' %></div></div>
  <div class="stat-item"><span class="icon">📍</span><div class="num">32</div><div class="label"><%= isEn ? 'Destinations' : '热门目的地' %></div></div>
  <div class="stat-item"><span class="icon">⭐</span><div class="num">96%</div><div class="label"><%= isEn ? 'Satisfaction' : '满意度' %></div></div>
  <div class="stat-item"><span class="icon">💬</span><div class="num">24h</div><div class="label"><%= isEn ? 'Online' : '客服在线' %></div></div>
  <div class="stat-item"><span class="icon">💰</span><div class="num"><%= (typeof bookingCount !== 'undefined' ? (bookingCount * 2500).toFixed(0) : '9999+') %></div><div class="label"><%= isEn ? 'Served' : '服务人次' %></div></div>
</div>

<!-- ========== QUICK NAV (sticky) ========== -->
<div class="sec-nav-wrap">
<div class="sec-nav">
  <a href="#sec-hot">🔥 <%= isEn ? 'Hot' : '热门线路' %></a>
  <a href="#sec-promo">💰 <%= isEn ? 'Deals' : '限时特惠' %></a>
  <% if (recommendTours && recommendTours.length > 0) { %><a href="#sec-recommend">🎯 <%= isEn ? 'For You' : '为你推荐' %></a><% } %>
  <a href="#sec-nearby">📍 <%= isEn ? 'Nearby' : '周边游' %></a>
  <a href="#sec-dest">🌍 <%= isEn ? 'Destinations' : '目的地' %></a>
  <a href="/nearby" style="border-color:var(--blue);color:var(--blue);">📍 <%= isEn ? 'All Nearby' : '完整周边' %></a>
</div>
</div>

<!-- ========== HOT TOURS ========== -->
<div class="sec-title" id="sec-hot">
  <h2 class="label"><span class="bar"></span>🏝️ <%= __('home.hotTours') %></h2>
  <p class="sub"><%= __('home.hotToursDesc') %></p>
</div>

<div class="tour-grid">
  <% hotTours.forEach(function(tour, idx) { %>
    <a href="/tour/<%= tour.id %><%= isEn ? '?lang=en' : '' %>" style="text-decoration:none;color:inherit;">
      <div class="tour-card <%= idx < 3 ? 'featured' : '' %>">
        <div class="card-img">
          <img src="/img/<%= tour.image %>" alt="<%= tt(tour, 'title') %>">
          <span class="tag"><%= tt(tour, 'type_label') %></span>
          <% if (tour.is_promotion) { %><span class="tag-promo"><%= isEn ? 'SALE' : '特价' %></span><% } %>
          <div class="badge-overlay">
            <% if (tour.days) { %><span>🗓️ <%= tour.days %></span><% } %>
            <% if (tour.satisfaction) { %><span>⭐ <%= tour.satisfaction %></span><% } %>
          </div>
        </div>
        <div class="card-body">
          <h3><%= tt(tour, 'title') %></h3>
          <p class="desc"><%= tt(tour, 'description') %></p>
          <div class="meta">
            <span class="price">¥&nbsp;<b><%= tour.price %></b><%= isEn ? " from" : "起" %>
              <% if (tour.original_price > tour.price) { %>
                <span style="font-size:11px;text-decoration:line-through;color:#bbb;font-weight:normal;">¥<%= tour.original_price %></span>
              <% } %>
            </span>
            <span class="rating">🔥 <%= (idx + 1) %></span>
          </div>
        </div>
      </div>
    </a>
  <% }) %>
</div>

<!-- ========== PROMOTIONS ========== -->
<div class="promo-wrap" id="sec-promo">
<div class="sec-title">
  <h2 class="label"><span class="bar"></span>🔥 <%= __('home.promotions') %></h2>
  <p class="sub"><%= __('home.promotionsDesc') %></p>
</div>
<div class="tour-grid">
  <% hotTours.filter(t => t.is_promotion).slice(0, 4).forEach(function(tour) { %>
    <a href="/tour/<%= tour.id %><%= isEn ? '?lang=en' : '' %>" style="text-decoration:none;color:inherit;">
      <div class="tour-card" style="border-top:3px solid var(--orange);">
        <div class="card-img">
          <img src="/img/<%= tour.image %>" alt="<%= tt(tour, 'title') %>">
          <span class="tag"><%= tt(tour, 'type_label') %></span>
          <span class="tag-promo"><%= isEn ? '🔥 SALE' : '🔥 特价' %></span>
          <div class="badge-overlay">
            <span>💰 <%- isEn ? 'Save' : '省' %> ¥<%= (tour.original_price - tour.price).toFixed(0) %></span>
          </div>
        </div>
        <div class="card-body">
          <h3><%= tt(tour, 'title') %></h3>
          <p class="desc"><%= tt(tour, 'description') %></p>
          <div class="meta">
            <span class="price">¥&nbsp;<b><%= tour.price %></b><%= isEn ? " from" : "起" %>
              <span style="font-size:11px;text-decoration:line-through;color:#bbb;">¥<%= tour.original_price %></span>
            </span>
            <span class="rating">⏰ <%= tour.promotion_end ? tour.promotion_end.slice(0,7) : (isEn ? 'Limited' : '限时') %></span>
          </div>
        </div>
      </div>
    </a>
  <% }) %>
</div>
</div>

<!-- ========== PERSONALIZED RECOMMENDATIONS ========== -->
<% if (typeof recommendTours !== 'undefined' && recommendTours.length > 0) { %>
<div class="sec-title" id="sec-recommend">
  <h2 class="label"><span class="bar"></span>🎯 <%= isEn ? 'Recommended for You' : '为你推荐' %></h2>
  <p class="sub"><%= isEn ? 'Based on your browsing and interests' : '基于你的浏览和兴趣偏好' %></p>
</div>
<div class="tour-grid">
  <% recommendTours.slice(0, 6).forEach(function(tour) { %>
    <a href="/tour/<%= tour.id %><%= isEn ? '?lang=en' : '' %>" style="text-decoration:none;color:inherit;">
      <div class="tour-card" style="border-left:3px solid var(--orange);">
        <div class="card-img">
          <img src="/img/<%= tour.image %>" alt="<%= tt(tour, 'title') %>">
          <span class="tag"><%= tt(tour, 'type_label') %></span>
          <div class="badge-overlay">
            <span><%= typeof recommendReasons !== 'undefined' && recommendReasons[tour.id] ? recommendReasons[tour.id] : '🎯 猜你喜欢' %></span>
          </div>
        </div>
        <div class="card-body">
          <h3><%= tt(tour, 'title') %></h3>
          <p class="desc"><%= tt(tour, 'description') %></p>
          <div class="meta">
            <span class="price">¥&nbsp;<b><%= tour.price %></b><%= isEn ? " from" : "起" %></span>
            <span class="rating">⭐ <%= tour.satisfaction %></span>
          </div>
        </div>
      </div>
    </a>
  <% }) %>
</div>
<% } %>

<!-- ========== NEARBY TOURS ========== -->
<div class="sec-title" id="sec-nearby">
  <h2 class="label"><span class="bar"></span>📍 <%= isEn ? 'Nearby Tours' : '附近旅游' %></h2>
  <p class="sub"><%= isEn ? 'Discover tours near your location' : '发现身边最近的旅游好去处' %></p>
</div>

<% if (typeof nearbyTours !== 'undefined' && nearbyTours.length > 0) { %>
<div class="tour-grid" style="padding-bottom:4px;">
  <% nearbyTours.forEach(function(tour) { %>
    <a href="/tour/<%= tour.id %><%= isEn ? '?lang=en' : '' %>" style="text-decoration:none;color:inherit;">
      <div class="tour-card" style="border-left:3px solid var(--blue);">
        <div class="card-img">
          <img src="/img/<%= tour.image %>" alt="<%= tt(tour, 'title') %>">
          <span class="tag"><%= tt(tour, 'type_label') %></span>
          <div class="badge-overlay">
            <span>📍 <%= tour.city %></span>
            <span>📏 <%= tour.distance %>km</span>
          </div>
        </div>
        <div class="card-body">
          <h3><%= tt(tour, 'title') %></h3>
          <p class="desc"><%= tt(tour, 'description') %></p>
          <div class="meta">
            <span class="price">¥&nbsp;<b><%= tour.price %></b><%= isEn ? " from" : "起" %></span>
            <span class="rating">⭐ <%= tour.satisfaction %></span>
          </div>
        </div>
      </div>
    </a>
  <% }) %>
</div>
<div class="nearby-bar" style="padding-top:4px;">
  <a href="/nearby" class="nearby-link">📍 <%= isEn ? 'View All Nearby Tours' : '查看全部附近线路' %> →</a>
</div>
<% } else { %>
<div class="nearby-bar">
  <button class="nearby-btn" onclick="enableNearby()">📍 <%= isEn ? 'Enable Location' : '开启定位' %></button>
  <a href="/nearby" class="nearby-link"><%= isEn ? 'Browse all destinations' : '浏览全部目的地' %> →</a>
</div>
<% } %>

<!-- ========== CTA BANNER ========== -->
<div class="cta-banner">
  <a href="/kefu" style="text-decoration:none;display:block;">
    <div class="cta-inner">
      <div class="cta-text">
        <h3>💬 <%= isEn ? 'Need Help? We\'re Online!' : '需要帮助？我们在线！' %></h3>
        <p><%= isEn ? 'One-on-one pro travel consultant, 24/7' : '专业旅游顾问 · 一对一服务 · 全天候在线' %></p>
      </div>
      <div class="cta-phone">
        <div class="num">📞 400-888-9999</div>
        <div class="hours"><%= __('kefu.contactHours') %></div>
      </div>
      <span class="cta-btn"><%= isEn ? 'Chat Now' : '咨询客服' %> →</span>
    </div>
  </a>
</div>

