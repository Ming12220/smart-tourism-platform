<% let path='/book'; let title='预订线路 - 智慧旅游'; %>
<%- include('partials/header', { path, title }) %>

<div style="padding-top:60px;max-width:1200px;margin:0 auto;padding-left:15px;padding-right:15px;">
  <div style="font-size:14px;color:#888;padding:15px 0;border-bottom:1px solid #eee;">
    <a href="/" style="color:#888;">首页</a> &gt;
    <a href="/tour/<%= tour.id %>" style="color:#888;"><%= tour.title %></a> &gt;
    <span style="color:#333;">在线预订</span>
  </div>

  <h1 style="color:#333;margin:25px 0;">📋 在线预订</h1>

  <% if (typeof error !== 'undefined' && error) { %>
    <div style="background:#f8d7da;color:#721c24;padding:12px;border-radius:4px;margin-bottom:20px;text-align:center;"><%= error %></div>
  <% } %>

  <div style="display:grid;grid-template-columns:1.5fr 1fr;gap:30px;">
    <!-- Booking Form -->
    <div style="background:#fff;border:1px solid #eee;border-radius:8px;padding:30px;">
      <h2 style="color:#333;font-size:18px;margin:0 0 5px;">✏️ 填写预订信息</h2>
      <p style="color:#888;font-size:13px;margin-bottom:25px;">请填写以下信息，提交后我们会尽快与您确认</p>

      <form method="POST" action="/book/<%= tour.id %>">
        <!-- Tour Summary -->
        <div style="background:#f9f9f9;border-radius:6px;padding:15px;margin-bottom:25px;display:flex;gap:15px;align-items:center;">
          <img src="/img/<%= tour.image %>" alt="" style="width:100px;height:70px;object-fit:cover;border-radius:4px;">
          <div>
            <div style="font-weight:bold;color:#333;font-size:15px;"><%= tour.title %></div>
            <div style="color:#888;font-size:13px;margin-top:3px;"><%= tour.days %> | <%= tour.type_label %></div>
            <div style="color:#ff6600;font-size:18px;font-weight:bold;margin-top:5px;">¥<%= tour.price %> <span style="font-size:13px;color:#888;font-weight:normal;">/位</span></div>
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
          <div>
            <label style="display:block;margin-bottom:5px;color:#555;font-size:14px;font-weight:bold;">出行日期 *</label>
            <input type="date" name="travel_date" required
                   min="<%= new Date().toISOString().split('T')[0] %>"
                   style="width:100%;padding:12px;border:1px solid #ddd;border-radius:6px;font-size:15px;">
          </div>
          <div>
            <label style="display:block;margin-bottom:5px;color:#555;font-size:14px;font-weight:bold;">联系电话 *</label>
            <input type="tel" name="phone" required placeholder="请输入手机号码"
                   style="width:100%;padding:12px;border:1px solid #ddd;border-radius:6px;font-size:15px;">
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
          <div>
            <label style="display:block;margin-bottom:5px;color:#555;font-size:14px;font-weight:bold;">成人人数 *</label>
            <input type="number" name="adults" min="1" max="50" value="1"
                   onchange="updatePrice()"
                   style="width:100%;padding:12px;border:1px solid #ddd;border-radius:6px;font-size:15px;">
          </div>
          <div>
            <label style="display:block;margin-bottom:5px;color:#555;font-size:14px;font-weight:bold;">儿童人数</label>
            <input type="number" name="children" min="0" max="50" value="0"
                   onchange="updatePrice()"
                   style="width:100%;padding:12px;border:1px solid #ddd;border-radius:6px;font-size:15px;">
            <span style="font-size:12px;color:#888;">儿童价 ¥<%= (tour.price * 0.6).toFixed(0) %>/位</span>
          </div>
        </div>

        <div style="margin-bottom:20px;">
          <label style="display:block;margin-bottom:5px;color:#555;font-size:14px;font-weight:bold;">电子邮箱</label>
          <input type="email" name="email" placeholder="选填，用于接收预订确认邮件"
                 style="width:100%;padding:12px;border:1px solid #ddd;border-radius:6px;font-size:15px;">
        </div>

        <div style="margin-bottom:25px;">
          <label style="display:block;margin-bottom:5px;color:#555;font-size:14px;font-weight:bold;">备注信息</label>
          <textarea name="note" placeholder="如：特殊饮食需求、航班偏好等" rows="3"
                    style="width:100%;padding:12px;border:1px solid #ddd;border-radius:6px;font-size:14px;resize:vertical;"></textarea>
        </div>

        <!-- Price Summary (live update) -->
        <div style="background:#f0f8ff;border-radius:6px;padding:20px;margin-bottom:25px;">
          <h3 style="color:#333;font-size:15px;margin:0 0 15px;">💰 费用明细</h3>
          <div id="priceDetail">
            <div style="display:flex;justify-content:space-between;font-size:14px;color:#666;margin-bottom:8px;">
              <span>成人（1位 × ¥<%= tour.price %>）</span>
              <span>¥<%= tour.price %></span>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:14px;color:#666;margin-bottom:8px;">
              <span>儿童（0位）</span>
              <span>¥0</span>
            </div>
            <hr style="border:none;border-top:1px dashed #ddd;">
            <div style="display:flex;justify-content:space-between;font-size:18px;font-weight:bold;color:#ff6600;">
              <span>总计</span>
              <span id="totalPrice">¥<%= tour.price %></span>
            </div>
          </div>
        </div>

        <button type="submit" style="width:100%;padding:15px;background:linear-gradient(135deg,#ff6600,#ff4500);color:#fff;border:none;border-radius:8px;font-size:18px;font-weight:bold;cursor:pointer;box-shadow:0 4px 15px rgba(255,102,0,0.3);">
          ✅ 确认预订
        </button>
      </form>
    </div>

    <!-- Sidebar -->
    <div>
      <div style="background:#fff;border:1px solid #eee;border-radius:8px;padding:25px;position:sticky;top:80px;margin-bottom:20px;">
        <h3 style="color:#333;margin:0 0 15px;">📌 预订须知</h3>
        <ul style="margin:0;padding-left:18px;color:#666;font-size:13px;line-height:2;">
          <li>预订后客服将在2小时内与您确认</li>
          <li>支持在线支付或到店付款</li>
          <li>出行前7天可免费取消</li>
          <li>请携带有效身份证件出行</li>
          <li>建议购买旅游意外险</li>
        </ul>
      </div>
      <div style="background:#fff;border:1px solid #eee;border-radius:8px;padding:25px;text-align:center;">
        <div style="font-size:32px;margin-bottom:10px;">📞</div>
        <h3 style="color:#333;font-size:16px;margin:0 0 5px;">客服热线</h3>
        <div style="color:#ff6600;font-size:24px;font-weight:bold;">400-888-9999</div>
        <p style="color:#888;font-size:12px;margin-top:5px;">周一至周日 9:00-21:00</p>
      </div>
    </div>
  </div>
</div>

<script>
  const unitPrice = <%= tour.price %>;
  const childPrice = <%= (tour.price * 0.6).toFixed(2) %>;

  function updatePrice() {
    const adults = parseInt(document.querySelector('[name=adults]').value) || 1;
    const children = parseInt(document.querySelector('[name=children]').value) || 0;
    const total = adults * unitPrice + children * childPrice;
    document.getElementById('totalPrice').textContent = '¥' + total.toFixed(0);

    // Update detail
    const detail = document.getElementById('priceDetail');
    detail.innerHTML = `
      <div style="display:flex;justify-content:space-between;font-size:14px;color:#666;margin-bottom:8px;">
        <span>成人（${adults}位 × ¥${unitPrice}）</span>
        <span>¥${(adults * unitPrice).toFixed(0)}</span>
      </div>
      <div style="display:flex;justify-content:space-between;font-size:14px;color:#666;margin-bottom:8px;">
        <span>儿童（${children}位 × ¥${childPrice}）</span>
        <span>¥${(children * childPrice).toFixed(0)}</span>
      </div>
      <hr style="border:none;border-top:1px dashed #ddd;">
      <div style="display:flex;justify-content:space-between;font-size:18px;font-weight:bold;color:#ff6600;">
        <span>总计</span>
        <span>¥${total.toFixed(0)}</span>
      </div>`;
  }
</script>

<%- include('partials/footer') %>
