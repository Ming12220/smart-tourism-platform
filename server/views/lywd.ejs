<% let path='/lywd'; let title=__('site.title.lywd'); %>
<%- include('partials/header', { path, title }) %>

<div class="content-wrapper" style="display:block;padding-top:60px;">
  <div style="max-width:1400px;margin:0 auto;">
    <h1 style="color:#666;font-size:28px;border-bottom:2px solid #59b200;padding-bottom:15px;"><%= __('lywd.title') %></h1>
    <p style="color:#898988;font-size:14px;margin-top:5px;"><%= __('lywd.desc') %></p>

    <div style="display:grid;grid-template-columns:2fr 1fr;gap:30px;margin-top:20px;">
      <!-- Main Q&A List -->
      <div>
        <% questions.forEach(function(q) { %>
          <div style="border:1px solid #ececec;border-radius:4px;padding:25px;margin-bottom:20px;transition:box-shadow 0.3s;"
               onmouseover="this.style.boxShadow='0 0 8px #ccc'" onmouseout="this.style.boxShadow='none'">
            <div style="margin-bottom:5px;">
              <span style="color:#959595;font-size:13px;">
                <img src="/img/logo.png" alt="" style="width:30px;height:30px;border-radius:50%;vertical-align:middle;margin-right:5px;">
                <%= q.author || __('lywd.anonymous') %>
              </span>
            </div>
            <div style="margin-bottom:10px;">
              <a href="javascript:void(0)" onclick="toggleAnswer(<%= q.id %>)" style="color:#323232;font-size:16px;font-weight:bold;text-decoration:none;">
                <%= tt(q, 'title') %>
              </a>
            </div>
            <p style="color:#646464;font-size:14px;line-height:1.6;margin:0 0 10px 0;"><%= (q.content || '').substring(0, 200) %><%= (q.content || '').length > 200 ? '...' : '' %></p>
            <div style="display:flex;justify-content:space-between;align-items:center;font-size:12px;color:#959595;">
              <div>
                <% if (q.tags) { %>
                  <% q.tags.split('|').forEach(function(tag) { %>
                    <span style="background:#f0f0f0;padding:2px 10px;border-radius:15px;margin-right:5px;"><%= tag %></span>
                  <% }) %>
                <% } %>
              </div>
              <div>
                <span style="margin-right:15px;">👁️ <%= q.views %></span>
                <span>💬 <%= q.answer_count || q.answers || 0 %> <%= __('lywd.answers') %></span>
              </div>
            </div>
            <!-- Answers (hidden by default) -->
            <div id="answer_<%= q.id %>" class="answers-section" style="display:none;margin-top:15px;padding-top:15px;border-top:1px dashed #ddd;">
              <p style="color:#888;font-size:13px;"><%= __('lywd.loading') %></p>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Sidebar -->
      <div>
        <div style="border:2px solid #efefef;border-radius:4px;margin-bottom:20px;">
          <div style="padding:10px;background:#fafafa;border-bottom:1px solid #efefef;">
            <span style="font-size:15px;color:#767676;">❓ <%= __('lywd.hotQuestions') %></span>
          </div>
          <div style="padding:15px;">
            <ol style="margin:0;padding-left:18px;color:#686868;line-height:2.2;font-size:14px;">
              <% questions.slice(0, 5).forEach(function(q) { %>
                <li><a href="javascript:void(0)" onclick="toggleAnswer(<%= q.id %>)" style="color:#323232;"><%= (tt(q, 'title') || q.title).substring(0, 25) %><%= q.title.length > 25 ? '...' : '' %></a></li>
              <% }) %>
            </ol>
          </div>
        </div>
        <div style="background:#f9f9f9;border:1px solid #efefef;border-radius:4px;padding:20px;text-align:center;">
          <p style="color:#666;font-size:14px;"><%= __('lywd.noAnswer') %></p>
          <p style="color:#959595;font-size:13px;"><%= __('lywd.contactHint') %></p>
          <a href="/kefu" style="display:inline-block;padding:10px 30px;background:#59b200;color:#fff;border-radius:4px;text-decoration:none;margin-top:10px;">💬 <%= __('lywd.contactBtn') %></a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Store loaded answers
  const answersCache = {};
  const lang = '<%= lang %>';
  const i18n = {
    loading: '<%= __('lywd.loading') %>',
    loadError: '<%= __('lywd.loadError') %>',
    noAnswers: '<%= __('lywd.noAnswersYet') %>',
    useful: '<%= __('lywd.useful') %>'
  };

  async function toggleAnswer(questionId) {
    const section = document.getElementById('answer_' + questionId);
    if (section.style.display === 'block') {
      section.style.display = 'none';
      return;
    }
    section.style.display = 'block';

    if (answersCache[questionId]) {
      renderAnswers(section, answersCache[questionId]);
      return;
    }

    try {
      const res = await fetch('/api/questions/' + questionId);
      const data = await res.json();
      if (data.success) {
        answersCache[questionId] = data.data.answers || [];
        renderAnswers(section, answersCache[questionId]);
      }
    } catch (e) {
      section.innerHTML = '<p style="color:#999;font-size:13px;">' + i18n.loadError + '</p>';
    }
  }

  function renderAnswers(section, answers) {
    if (!answers || answers.length === 0) {
      section.innerHTML = '<p style="color:#999;font-size:13px;">' + i18n.noAnswers + '</p>';
      return;
    }
    let html = '';
    answers.forEach(a => {
      const date = new Date(a.created_at);
      const dateStr = lang === 'en'
        ? date.toLocaleDateString('en-US', {year:'numeric',month:'short',day:'numeric'})
        : date.toLocaleDateString('zh-CN');
      html += `
        <div style="margin-bottom:15px;padding:12px;background:#f9f9f9;border-radius:4px;">
          <div style="font-size:13px;color:#888;margin-bottom:5px;">
            <strong style="color:#333;">${a.author}</strong> · ${dateStr}
          </div>
          <p style="margin:0;color:#555;font-size:14px;line-height:1.6;">${a.content}</p>
          <div style="margin-top:8px;font-size:12px;color:#999;">❤️ ${a.likes || 0} ${i18n.useful}</div>
        </div>`;
    });
    section.innerHTML = html;
  }
</script>

<%- include('partials/footer') %>
