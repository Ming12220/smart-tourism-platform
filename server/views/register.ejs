<% let path='/register'; let title=__('site.title.register'); %>
<%- include('partials/header', { path, title }) %>

<div style="min-height:500px;display:flex;align-items:center;justify-content:center;background:#f5f5f5;padding:60px 15px;">
  <div style="background:#fff;border-radius:8px;padding:40px;width:100%;max-width:450px;box-shadow:0 4px 20px rgba(0,0,0,0.08);">
    <h2 style="text-align:center;color:#333;margin-bottom:30px;">📝 用户注册</h2>

    <% if (typeof error !== 'undefined' && error) { %>
      <div style="background:#f8d7da;color:#721c24;padding:10px;border-radius:4px;margin-bottom:20px;text-align:center;font-size:14px;"><%= error %></div>
    <% } %>

    <form method="POST" action="/register">
      <div style="margin-bottom:18px;">
        <label style="display:block;margin-bottom:6px;color:#555;font-size:14px;">用户名 *</label>
        <input type="text" name="username" required placeholder="请设置用户名"
               style="width:100%;padding:12px;border:1px solid #ddd;border-radius:4px;font-size:15px;">
      </div>
      <div style="margin-bottom:18px;">
        <label style="display:block;margin-bottom:6px;color:#555;font-size:14px;">电子邮箱</label>
        <input type="email" name="email" placeholder="选填"
               style="width:100%;padding:12px;border:1px solid #ddd;border-radius:4px;font-size:15px;">
      </div>
      <div style="margin-bottom:18px;">
        <label style="display:block;margin-bottom:6px;color:#555;font-size:14px;">手机号</label>
        <input type="tel" name="phone" placeholder="选填"
               style="width:100%;padding:12px;border:1px solid #ddd;border-radius:4px;font-size:15px;">
      </div>
      <div style="margin-bottom:18px;">
        <label style="display:block;margin-bottom:6px;color:#555;font-size:14px;">密码 *</label>
        <input type="password" name="password" required placeholder="至少6位密码"
               minlength="6" style="width:100%;padding:12px;border:1px solid #ddd;border-radius:4px;font-size:15px;">
      </div>
      <div style="margin-bottom:25px;">
        <label style="display:block;margin-bottom:6px;color:#555;font-size:14px;">确认密码 *</label>
        <input type="password" name="confirmPassword" required placeholder="再次输入密码"
               style="width:100%;padding:12px;border:1px solid #ddd;border-radius:4px;font-size:15px;">
      </div>
      <button type="submit" style="width:100%;padding:12px;background:#59b200;color:#fff;border:none;border-radius:4px;font-size:16px;cursor:pointer;">
        注册
      </button>
    </form>

    <p style="text-align:center;margin-top:20px;color:#888;font-size:14px;">
      已有账号？<a href="/login" style="color:#59b200;text-decoration:none;">立即登录</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>
