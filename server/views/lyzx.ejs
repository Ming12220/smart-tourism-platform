<% let path='/lyzx'; let title=__('site.title.lyzx'); %>
<%- include('partials/header', { path, title }) %>

<div class="content-wrapper" style="display:block;padding-top:60px;">
  <div style="max-width:1400px;margin:0 auto;">
    <h1 style="color:#666;font-size:28px;border-bottom:2px solid #59b200;padding-bottom:15px;">旅游咨询</h1>

    <div style="display:grid;grid-template-columns:2fr 1fr;gap:30px;margin-top:20px;">
      <!-- Main -->
      <div>
        <section style="margin-bottom:40px;">
          <h2 style="color:#444;font-size:22px;">公司简介</h2>
          <p style="color:#686868;line-height:2;font-size:15px;text-indent:2em;">
            智慧旅游在线服务平台成立于2020年，是一家专注于旅游信息服务和在线旅游预订的综合性平台。
            我们致力于为用户提供全面、准确、及时的旅游资讯，涵盖国内外热门景点介绍、精品旅游线路推荐、
            旅游攻略分享以及一站式在线预订服务。
          </p>
          <p style="color:#686868;line-height:2;font-size:15px;text-indent:2em;">
            平台依托先进的信息技术和丰富的旅游资源，与国内外多家知名旅行社、航空公司、酒店集团建立了
            长期稳定的合作关系。我们的目标是"让旅游更简单"，让每一位用户都能享受到便捷、高效、优质的旅游服务体验。
          </p>
        </section>

        <section style="margin-bottom:40px;">
          <h2 style="color:#444;font-size:22px;">服务优势</h2>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
            <div style="border:1px solid #e1e1e1;border-radius:8px;padding:20px;text-align:center;">
              <div style="font-size:36px;margin-bottom:10px;">🌍</div>
              <h3 style="color:#333;font-size:16px;">全球资源</h3>
              <p style="color:#898988;font-size:13px;">覆盖全球50+国家和地区，1000+旅游线路</p>
            </div>
            <div style="border:1px solid #e1e1e1;border-radius:8px;padding:20px;text-align:center;">
              <div style="font-size:36px;margin-bottom:10px;">💰</div>
              <h3 style="color:#333;font-size:16px;">价格保障</h3>
              <p style="color:#898988;font-size:13px;">全网比价，买贵退差价，让您放心出行</p>
            </div>
            <div style="border:1px solid #e1e1e1;border-radius:8px;padding:20px;text-align:center;">
              <div style="font-size:36px;margin-bottom:10px;">👨‍💼</div>
              <h3 style="color:#333;font-size:16px;">专业顾问</h3>
              <p style="color:#898988;font-size:13px;">资深旅游顾问一对一服务，量身定制行程</p>
            </div>
            <div style="border:1px solid #e1e1e1;border-radius:8px;padding:20px;text-align:center;">
              <div style="font-size:36px;margin-bottom:10px;">🔒</div>
              <h3 style="color:#333;font-size:16px;">安全可靠</h3>
              <p style="color:#898988;font-size:13px;">正规旅行社资质，签订电子合同，售后无忧</p>
            </div>
          </div>
        </section>

        <section>
          <h2 style="color:#444;font-size:22px;">联系我们</h2>
          <div style="border:1px solid #e1e1e1;border-radius:8px;padding:25px;">
            <p style="color:#686868;font-size:15px;line-height:2;"><strong>地址：</strong>上海市浦东新区陆家嘴金融区888号智慧大厦18层</p>
            <p style="color:#686868;font-size:15px;line-height:2;"><strong>电话：</strong>400-888-9999</p>
            <p style="color:#686868;font-size:15px;line-height:2;"><strong>传真：</strong>021-8888-9999</p>
            <p style="color:#686868;font-size:15px;line-height:2;"><strong>邮箱：</strong>service@smart-tourism.com</p>
            <p style="color:#686868;font-size:15px;line-height:2;"><strong>工作时间：</strong>周一至周日 9:00 - 21:00</p>
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <div>
        <div style="border:2px solid #efefef;border-radius:4px;margin-bottom:20px;">
          <div style="padding:10px;background:#fafafa;border-bottom:1px solid #efefef;">
            <span style="font-size:15px;color:#767676;">📞 在线留言</span>
          </div>
          <div style="padding:15px;">
            <form id="contactForm" onsubmit="event.preventDefault(); submitContact()">
              <div style="margin-bottom:10px;">
                <input type="text" name="name" placeholder="您的姓名" required style="width:100%;padding:8px;border:1px solid #ddd;border-radius:4px;">
              </div>
              <div style="margin-bottom:10px;">
                <input type="tel" name="phone" placeholder="联系电话" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:4px;">
              </div>
              <div style="margin-bottom:10px;">
                <input type="email" name="email" placeholder="电子邮箱" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:4px;">
              </div>
              <div style="margin-bottom:10px;">
                <textarea name="message" placeholder="留言内容" rows="5" required style="width:100%;padding:8px;border:1px solid #ddd;border-radius:4px;resize:vertical;"></textarea>
              </div>
              <button type="submit" style="width:100%;padding:10px;background:#59b200;color:#fff;border:none;border-radius:4px;font-size:15px;cursor:pointer;">提交留言</button>
            </form>
            <p id="contactMsg" style="display:none;text-align:center;color:#59b200;margin-top:10px;font-size:14px;"></p>
          </div>
        </div>

        <div style="border:2px solid #efefef;border-radius:4px;">
          <div style="padding:10px;background:#fafafa;border-bottom:1px solid #efefef;">
            <span style="font-size:15px;color:#767676;">💡 旅游小贴士</span>
          </div>
          <div style="padding:15px;">
            <ul style="margin:0;padding-left:18px;color:#686868;line-height:2;font-size:14px;">
              <li>出行前记得查看目的地天气</li>
              <li>提前办理签证和购买保险</li>
              <li>随身携带重要证件复印件</li>
              <li>遵守当地法律法规和习俗</li>
              <li>注意饮食卫生和人身安全</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  async function submitContact() {
    const form = document.getElementById('contactForm');
    const data = { name: form.name.value, phone: form.phone.value, email: form.email.value, message: form.message.value };
    const res = await fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    const result = await res.json();
    const msg = document.getElementById('contactMsg');
    msg.textContent = result.message;
    msg.style.display = 'block';
    msg.style.color = result.success ? '#59b200' : '#dc3545';
    if (result.success) form.reset();
  }
</script>

<%- include('partials/footer') %>
