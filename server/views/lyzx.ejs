<% let path='/lyzx'; let title=__('site.title.lyzx'); %>
<%- include('partials/header', { path, title }) %>

<div class="content-wrapper" style="display:block;padding-top:60px;">
  <div style="max-width:1400px;margin:0 auto;">
    <h1 style="color:#666;font-size:28px;border-bottom:2px solid #59b200;padding-bottom:15px;"><%= __('lyzx.title') %></h1>
    <p style="color:#898988;font-size:14px;margin-top:5px;"><%= __('lyzx.desc') %></p>

    <div style="display:grid;grid-template-columns:2fr 1fr;gap:30px;margin-top:20px;">
      <!-- Main -->
      <div>
        <section style="margin-bottom:40px;">
          <h2 style="color:#444;font-size:22px;"><%= __('lyzx.about') %></h2>
          <p style="color:#686868;line-height:2;font-size:15px;text-indent:2em;"><%= __('lyzx.aboutP1') %></p>
          <p style="color:#686868;line-height:2;font-size:15px;text-indent:2em;"><%= __('lyzx.aboutP2') %></p>
        </section>

        <section style="margin-bottom:40px;">
          <h2 style="color:#444;font-size:22px;"><%= __('lyzx.advantages') %></h2>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
            <div style="border:1px solid #e1e1e1;border-radius:8px;padding:20px;text-align:center;">
              <div style="font-size:36px;margin-bottom:10px;">🌍</div>
              <h3 style="color:#333;font-size:16px;"><%= __('lyzx.adv1') %></h3>
              <p style="color:#898988;font-size:13px;"><%= __('lyzx.adv1Desc') %></p>
            </div>
            <div style="border:1px solid #e1e1e1;border-radius:8px;padding:20px;text-align:center;">
              <div style="font-size:36px;margin-bottom:10px;">💰</div>
              <h3 style="color:#333;font-size:16px;"><%= __('lyzx.adv2') %></h3>
              <p style="color:#898988;font-size:13px;"><%= __('lyzx.adv2Desc') %></p>
            </div>
            <div style="border:1px solid #e1e1e1;border-radius:8px;padding:20px;text-align:center;">
              <div style="font-size:36px;margin-bottom:10px;">👨‍💼</div>
              <h3 style="color:#333;font-size:16px;"><%= __('lyzx.adv3') %></h3>
              <p style="color:#898988;font-size:13px;"><%= __('lyzx.adv3Desc') %></p>
            </div>
            <div style="border:1px solid #e1e1e1;border-radius:8px;padding:20px;text-align:center;">
              <div style="font-size:36px;margin-bottom:10px;">🔒</div>
              <h3 style="color:#333;font-size:16px;"><%= __('lyzx.adv4') %></h3>
              <p style="color:#898988;font-size:13px;"><%= __('lyzx.adv4Desc') %></p>
            </div>
          </div>
        </section>

        <section>
          <h2 style="color:#444;font-size:22px;"><%= __('lyzx.contact') %></h2>
          <div style="border:1px solid #e1e1e1;border-radius:8px;padding:25px;">
            <p style="color:#686868;font-size:15px;line-height:2;"><strong><%= __('lyzx.addrLabel') %>：</strong><%= __('lyzx.addr') %></p>
            <p style="color:#686868;font-size:15px;line-height:2;"><strong><%= __('lyzx.phoneLabel') %>：</strong>400-888-9999</p>
            <p style="color:#686868;font-size:15px;line-height:2;"><strong><%= __('lyzx.faxLabel') %>：</strong>021-8888-9999</p>
            <p style="color:#686868;font-size:15px;line-height:2;"><strong><%= __('lyzx.emailLabel') %>：</strong>service@smart-tourism.com</p>
            <p style="color:#686868;font-size:15px;line-height:2;"><strong><%= __('lyzx.hoursLabel') %>：</strong><%= __('lyzx.hours') %></p>
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <div>
        <div style="border:2px solid #efefef;border-radius:4px;margin-bottom:20px;">
          <div style="padding:10px;background:#fafafa;border-bottom:1px solid #efefef;">
            <span style="font-size:15px;color:#767676;">📞 <%= __('lyzx.message') %></span>
          </div>
          <div style="padding:15px;">
            <form id="contactForm" onsubmit="event.preventDefault(); submitContact()">
              <div style="margin-bottom:10px;">
                <input type="text" name="name" id="contactName" placeholder="<%= __('lyzx.namePH') %>" required style="width:100%;padding:8px;border:1px solid #ddd;border-radius:4px;">
              </div>
              <div style="margin-bottom:10px;">
                <input type="tel" name="phone" id="contactPhone" placeholder="<%= __('lyzx.phonePH') %>" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:4px;">
              </div>
              <div style="margin-bottom:10px;">
                <input type="email" name="email" id="contactEmail" placeholder="<%= __('lyzx.emailPH') %>" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:4px;">
              </div>
              <div style="margin-bottom:10px;">
                <textarea name="message" id="contactMsgText" placeholder="<%= __('lyzx.msgPH') %>" rows="5" required style="width:100%;padding:8px;border:1px solid #ddd;border-radius:4px;resize:vertical;"></textarea>
              </div>
              <button type="submit" style="width:100%;padding:10px;background:#59b200;color:#fff;border:none;border-radius:4px;font-size:15px;cursor:pointer;"><%= __('lyzx.submitBtn') %></button>
            </form>
            <p id="contactFormMsg" style="display:none;text-align:center;color:#59b200;margin-top:10px;font-size:14px;"></p>
          </div>
        </div>

        <div style="border:2px solid #efefef;border-radius:4px;">
          <div style="padding:10px;background:#fafafa;border-bottom:1px solid #efefef;">
            <span style="font-size:15px;color:#767676;">💡 <%= __('lyzx.tips') %></span>
          </div>
          <div style="padding:15px;">
            <ul style="margin:0;padding-left:18px;color:#686868;line-height:2.2;font-size:14px;">
              <li><%= __('lyzx.tip1') %></li>
              <li><%= __('lyzx.tip2') %></li>
              <li><%= __('lyzx.tip3') %></li>
              <li><%= __('lyzx.tip4') %></li>
              <li><%= __('lyzx.tip5') %></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  async function submitContact() {
    const form = document.getElementById('contactForm');
    const data = {
      name: document.getElementById('contactName').value,
      phone: document.getElementById('contactPhone').value,
      email: document.getElementById('contactEmail').value,
      message: document.getElementById('contactMsgText').value
    };
    const res = await fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    const result = await res.json();
    const msg = document.getElementById('contactFormMsg');
    msg.textContent = result.message;
    msg.style.display = 'block';
    msg.style.color = result.success ? '#59b200' : '#dc3545';
    if (result.success) form.reset();
  }
</script>

<%- include('partials/footer') %>
