<% let path='/login'; let title='登录 - 智慧旅游'; %>
<%- include('partials/header', { path, title }) %>

<div style="min-height:500px;display:flex;align-items:center;justify-content:center;background:#f5f5f5;padding:60px 15px;">
  <div style="background:#fff;border-radius:8px;padding:40px;width:100%;max-width:400px;box-shadow:0 4px 20px rgba(0,0,0,0.08);">
    <h2 style="text-align:center;color:#333;margin-bottom:30px;">🔑 用户登录</h2>

    <% if (typeof error !== 'undefined' && error) { %>
      <div style="background:#f8d7da;color:#721c24;padding:10px;border-radius:4px;margin-bottom:20px;text-align:center;font-size:14px;"><%= error %></div>
    <% } %>

    <form method="POST" action="/login">
      <div style="margin-bottom:20px;">
        <label style="display:block;margin-bottom:6px;color:#555;font-size:14px;">用户名</label>
        <input type="text" name="username" required placeholder="请输入用户名"
               style="width:100%;padding:12px;border:1px solid #ddd;border-radius:4px;font-size:15px;">
      </div>
      <div style="margin-bottom:25px;">
        <label style="display:block;margin-bottom:6px;color:#555;font-size:14px;">密码</label>
        <input type="password" name="password" required placeholder="请输入密码"
               style="width:100%;padding:12px;border:1px solid #ddd;border-radius:4px;font-size:15px;">
      </div>
      <button type="submit" style="width:100%;padding:12px;background:#59b200;color:#fff;border:none;border-radius:4px;font-size:16px;cursor:pointer;">
        登录
      </button>
    </form>

    <p style="text-align:center;margin-top:20px;color:#888;font-size:14px;">
      还没有账号？<a href="/register" style="color:#59b200;text-decoration:none;">立即注册</a>
    </p>

    <div style="margin-top:20px;padding:12px;background:#f0f8ff;border-radius:4px;font-size:12px;color:#666;">
      <p style="margin:0 0 5px;"><strong>💡 测试账号</strong></p>
      <p style="margin:2px 0;">管理员：admin / admin123</p>
      <p style="margin:2px 0;">普通用户：testuser / 123456</p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
