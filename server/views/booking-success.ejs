<% let path='/booking'; let title='预订成功 - 智慧旅游'; %>
<%- include('partials/header', { path, title }) %>

<div style="min-height:500px;display:flex;align-items:center;justify-content:center;padding:80px 15px;background:#f5f5f5;">
  <div style="background:#fff;border-radius:12px;padding:50px;max-width:600px;width:100%;text-align:center;box-shadow:0 10px 40px rgba(0,0,0,0.08);">
    <div style="font-size:80px;margin-bottom:20px;">🎉</div>
    <h1 style="color:#333;margin:0 0 10px;">预订成功！</h1>
    <p style="color:#888;font-size:15px;">您的预订已提交，客服将在2小时内与您确认</p>

    <div style="background:#f0f8ff;border-radius:8px;padding:25px;margin:30px 0;text-align:left;">
      <h3 style="color:#333;font-size:16px;margin:0 0 15px;">📋 订单信息</h3>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:14px;">
        <div style="color:#888;">订单编号</div>
        <div style="color:#333;font-weight:bold;text-align:right;">#<%= booking.id %></div>

        <div style="color:#888;">线路名称</div>
        <div style="color:#333;text-align:right;"><%= booking.tour_title %></div>

        <div style="color:#888;">出行日期</div>
        <div style="color:#333;text-align:right;"><%= booking.travel_date %></div>

        <div style="color:#888;">人数</div>
        <div style="color:#333;text-align:right;"><%= booking.adults %> 位成人<%= booking.children > 0 ? ' + ' + booking.children + ' 位儿童' : '' %></div>

        <div style="color:#888;">总价</div>
        <div style="color:#ff6600;font-weight:bold;font-size:20px;text-align:right;">¥<%= booking.total_price.toFixed(0) %></div>

        <div style="color:#888;">订单状态</div>
        <div style="text-align:right;">
          <span style="background:#fff3cd;color:#856404;padding:3px 12px;border-radius:12px;font-size:12px;">⏳ 待确认</span>
        </div>
      </div>
    </div>

    <div style="background:#f9f9f9;border-radius:8px;padding:20px;margin-bottom:25px;">
      <p style="color:#666;font-size:13px;margin:0;">📞 如有疑问请拨打客服热线</p>
      <div style="color:#ff6600;font-size:22px;font-weight:bold;margin-top:5px;">400-888-9999</div>
    </div>

    <div style="display:flex;gap:15px;justify-content:center;">
      <a href="/my-bookings" style="padding:12px 30px;background:#59b200;color:#fff;border-radius:6px;text-decoration:none;font-size:15px;">📋 我的订单</a>
      <a href="/" style="padding:12px 30px;background:#fff;color:#333;border:1px solid #ddd;border-radius:6px;text-decoration:none;font-size:15px;">🏠 返回首页</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
