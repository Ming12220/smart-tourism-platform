<% let path='/admin/bookings'; let title='订单详情 - 智慧旅游'; %>
<%- include('../partials/header', { path, title }) %>

<style>
  .admin-layout { display:flex; min-height:calc(100vh - 60px); }
  .admin-sidebar { width:220px; background:#2c3e50; color:#fff; padding:20px 0; flex-shrink:0; }
  .admin-sidebar a { display:block; padding:12px 20px; color:#bdc3c7; text-decoration:none; font-size:14px; }
  .admin-sidebar a:hover, .admin-sidebar a.active { background:#34495e; color:#fff; }
  .admin-main { flex:1; padding:25px; background:#f5f6fa; }
  
  .detail-card { background:#fff; border-radius:10px; box-shadow:0 2px 15px rgba(0,0,0,0.06); overflow:hidden; }
  .detail-header { 
    background: linear-gradient(135deg, #2c3e50, #34495e);
    color:#fff; padding:25px 30px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:15px;
  }
  .detail-header h2 { margin:0; font-size:20px; }
  .detail-header .order-number { font-size:14px; opacity:0.8; }
  .detail-body { padding:30px; }

  .info-grid { display:grid; grid-template-columns:1fr 1fr; gap:30px; }
  .info-section { margin-bottom:25px; }
  .info-section h3 {
    font-size:15px; color:#2c3e50; margin:0 0 15px; padding-bottom:8px; border-bottom:2px solid #f0f0f0;
  }
  .info-row { display:flex; padding:8px 0; border-bottom:1px solid #f5f5f5; font-size:14px; }
  .info-row .label { width:120px; color:#888; flex-shrink:0; }
  .info-row .value { color:#333; flex:1; }

  .status-timeline { display:flex; align-items:center; gap:0; margin:20px 0; flex-wrap:wrap; }
  .timeline-step { display:flex; align-items:center; }
  .timeline-dot {
    width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center;
    font-size:14px; color:#fff; flex-shrink:0;
  }
  .timeline-dot.done { background:#59b200; }
  .timeline-dot.current { background:#ff6600; box-shadow:0 0 0 4px rgba(255,102,0,0.2); }
  .timeline-dot.pending { background:#ddd; }
  .timeline-line {
    width:40px; height:3px; flex-shrink:0;
  }
  .timeline-line.done { background:#59b200; }
  .timeline-line.pending { background:#ddd; }
  .timeline-label { font-size:11px; color:#888; text-align:center; margin-top:4px; min-width:32px; }

  .badge-status { display:inline-block; padding:6px 18px; border-radius:20px; font-size:14px; font-weight:bold; }
  .badge-pending { background:#fff3cd; color:#856404; }
  .badge-confirmed { background:#d4edda; color:#155724; }
  .badge-completed { background:#cce5ff; color:#004085; }
  .badge-cancelled { background:#f8d7da; color:#721c24; }

  .price-breakdown { background:#f8f9fa; border-radius:8px; padding:15px; margin:10px 0; }
  .price-row { display:flex; justify-content:space-between; padding:5px 0; font-size:14px; }
  .price-row.total { border-top:2px solid #ff6600; margin-top:8px; padding-top:10px; font-size:16px; font-weight:bold; color:#ff6600; }

  .action-bar { display:flex; gap:10px; margin-top:20px; flex-wrap:wrap; }
  .action-bar form { display:inline; }
  .btn { padding:10px 25px; border:none; border-radius:6px; font-size:14px; font-weight:600; cursor:pointer; transition:0.3s; text-decoration:none; display:inline-block; }
  .btn:hover { opacity:0.9; transform:translateY(-1px); }
  .btn-primary { background:#59b200; color:#fff; }
  .btn-warning { background:#ff6600; color:#fff; }
  .btn-info { background:#3498db; color:#fff; }
  .btn-danger { background:#e74c3c; color:#fff; }
  .btn-outline { background:#fff; color:#666; border:1px solid #ddd; }

  .tour-card { display:flex; gap:15px; align-items:center; background:#f9f9f9; border-radius:8px; padding:15px; }
  .tour-card img { width:80px; height:80px; border-radius:6px; object-fit:cover; }
  .tour-card h4 { margin:0 0 4px; font-size:15px; color:#2c3e50; }
  .tour-card p { margin:0; font-size:13px; color:#888; }

  @media (max-width:768px) {
    .info-grid { grid-template-columns:1fr; }
    .detail-body { padding:15px; }
  }
</style>

<div class="admin-layout">
  <div class="admin-sidebar">
    <div style="padding:15px 20px;border-bottom:1px solid #34495e;margin-bottom:10px;"><strong>⚙️ 管理面板</strong></div>
    <a href="/admin"><span class="icon">📊</span> 概览</a>
    <a href="/admin/tours"><span class="icon">🏝️</span> 线路管理</a>
    <a href="/admin/questions"><span class="icon">❓</span> 问答管理</a>
    <a href="/admin/users"><span class="icon">👥</span> 用户管理</a>
    <a href="/admin/contacts"><span class="icon">📬</span> 留言管理</a>
    <a href="/admin/bookings" class="active"><span class="icon">📋</span> 订单管理</a>
    <a href="/" style="margin-top:30px;border-top:1px solid #34495e;padding-top:15px;"><span class="icon">🏠</span> 返回前台</a>
  </div>
  <div class="admin-main">
    <div style="margin-bottom:20px;">
      <a href="/admin/bookings" style="color:#3498db;text-decoration:none;font-size:14px;">← 返回订单列表</a>
    </div>

    <div class="detail-card">
      <!-- Header -->
      <div class="detail-header">
        <div>
          <h2>📋 订单详情</h2>
          <span class="order-number">订单 #<%= booking.id %> · 下单时间：<%= new Date(booking.created_at).toLocaleString('zh-CN') %></span>
        </div>
        <span class="badge-status badge-<%= booking.status %>">
          <% if (booking.status === 'pending') { %>⏳ 待确认
          <% } else if (booking.status === 'confirmed') { %>✅ 已确认
          <% } else if (booking.status === 'completed') { %>🎉 已完成
          <% } else { %>❌ 已取消<% } %>
        </span>
      </div>

      <div class="detail-body">
        <!-- Status Timeline -->
        <div class="info-section">
          <h3>📊 订单状态</h3>
          <div class="status-timeline">
            <% var steps = [
              { key: 'pending', label: '待确认', icon: '📝' },
              { key: 'confirmed', label: '已确认', icon: '✅' },
              { key: 'completed', label: '已完成', icon: '🎉' }
            ]; %>
            <% var statusOrder = { 'pending': 0, 'confirmed': 1, 'completed': 2, 'cancelled': -1 }; %>
            <% var currentIdx = statusOrder[booking.status] !== undefined ? statusOrder[booking.status] : -1; %>
            <% steps.forEach(function(step, idx) { %>
              <div class="timeline-step">
                <div style="text-align:center;">
                  <div class="timeline-dot <%= booking.status === 'cancelled' ? 'pending' : (idx <= currentIdx ? 'done' : (idx === currentIdx && booking.status !== 'cancelled' ? 'current' : 'pending')) %>">
                    <%= booking.status === 'cancelled' && idx === 0 ? '❌' : step.icon %>
                  </div>
                  <div class="timeline-label"><%= step.label %></div>
                </div>
                <% if (idx < steps.length - 1) { %>
                  <div class="timeline-line <%= booking.status === 'cancelled' ? 'pending' : (idx < currentIdx ? 'done' : 'pending') %>"></div>
                <% } %>
              </div>
            <% }); %>
          </div>
          <% if (booking.status === 'cancelled') { %>
            <p style="color:#e74c3c;font-size:13px;margin:5px 0 0;">⚠️ 该订单已被取消</p>
          <% } %>
        </div>

        <div class="info-grid">
          <!-- Left Column -->
          <div>
            <!-- Customer Info -->
            <div class="info-section">
              <h3>👤 客户信息</h3>
              <div class="info-row"><span class="label">客户姓名</span><span class="value"><%= booking.username %></span></div>
              <div class="info-row"><span class="label">联系电话</span><span class="value"><a href="tel:<%= booking.phone %>" style="color:#3498db;"><%= booking.phone %></a></span></div>
              <% if (booking.email) { %>
              <div class="info-row"><span class="label">电子邮箱</span><span class="value"><%= booking.email %></span></div>
              <% } %>
              <% if (booking.user_id) { %>
              <div class="info-row"><span class="label">用户ID</span><span class="value">#<%= booking.user_id %></span></div>
              <% } %>
            </div>

            <!-- Tour Info -->
            <div class="info-section">
              <h3>🏝️ 线路信息</h3>
              <div class="tour-card">
                <img src="/img/<%= booking.image || 'tour1.jpg' %>" alt="<%= booking.tour_title %>">
                <div>
                  <h4><%= booking.tour_title %></h4>
                  <p>行程天数：<%= booking.days || '待定' %></p>
                  <% if (booking.type_label) { %><p>类型：<%= booking.type_label %></p><% } %>
                </div>
              </div>
            </div>

            <!-- Notes -->
            <div class="info-section">
              <h3>📝 备注信息</h3>
              <% if (booking.note) { %>
                <div style="background:#fff8e1;border:1px solid #ffe082;border-radius:6px;padding:12px;font-size:14px;color:#795548;">
                  <%= booking.note %>
                </div>
              <% } else { %>
                <p style="color:#bbb;font-size:14px;">无备注</p>
              <% } %>
            </div>
          </div>

          <!-- Right Column -->
          <div>
            <!-- Travel Info -->
            <div class="info-section">
              <h3>📅 出行信息</h3>
              <div class="info-row"><span class="label">出行日期</span><span class="value" style="font-weight:bold;"><%= booking.travel_date %></span></div>
              <div class="info-row"><span class="label">成人人数</span><span class="value"><%= booking.adults %> 位</span></div>
              <div class="info-row"><span class="label">儿童人数</span><span class="value"><%= booking.children %> 位</span></div>
              <div class="info-row"><span class="label">总人数</span><span class="value"><strong><%= parseInt(booking.adults) + parseInt(booking.children) %></strong> 位</span></div>
              <div class="info-row"><span class="label">下单时间</span><span class="value"><%= new Date(booking.created_at).toLocaleString('zh-CN') %></span></div>
              <% if (booking.updated_at && booking.updated_at !== booking.created_at) { %>
              <div class="info-row"><span class="label">最后更新</span><span class="value"><%= new Date(booking.updated_at).toLocaleString('zh-CN') %></span></div>
              <% } %>
            </div>

            <!-- Price Breakdown -->
            <div class="info-section">
              <h3>💰 费用明细</h3>
              <div class="price-breakdown">
                <div class="price-row">
                  <span>成人单价</span>
                  <span>¥<%= (booking.total_price / (parseInt(booking.adults) + parseInt(booking.children) * 0.6)).toFixed(0) %></span>
                </div>
                <div class="price-row">
                  <span>成人 × <%= booking.adults %> 位</span>
                  <span>¥<%= (booking.total_price / (parseInt(booking.adults) + parseInt(booking.children) * 0.6) * booking.adults).toFixed(0) %></span>
                </div>
                <% if (parseInt(booking.children) > 0) { %>
                <div class="price-row">
                  <span>儿童(60%) × <%= booking.children %> 位</span>
                  <span>¥<%= (booking.total_price / (parseInt(booking.adults) + parseInt(booking.children) * 0.6) * 0.6 * booking.children).toFixed(0) %></span>
                </div>
                <% } %>
                <div class="price-row total">
                  <span>¥ 合计</span>
                  <span>¥<%= booking.total_price.toFixed(0) %></span>
                </div>
              </div>
            </div>

            <!-- Actions -->
            <div class="info-section">
              <h3>⚡ 操作</h3>
              <div class="action-bar">
                <% if (booking.status === 'pending') { %>
                  <form method="POST" action="/admin/bookings/status" onsubmit="return confirm('确认该订单？')">
                    <input type="hidden" name="id" value="<%= booking.id %>">
                    <input type="hidden" name="status" value="confirmed">
                    <input type="hidden" name="redirect" value="/admin/bookings/detail/<%= booking.id %>">
                    <button class="btn btn-primary">✅ 确认订单</button>
                  </form>
                  <form method="POST" action="/admin/bookings/status" onsubmit="return confirm('取消该订单？')">
                    <input type="hidden" name="id" value="<%= booking.id %>">
                    <input type="hidden" name="status" value="cancelled">
                    <input type="hidden" name="redirect" value="/admin/bookings/detail/<%= booking.id %>">
                    <button class="btn btn-danger">❌ 取消订单</button>
                  </form>
                <% } else if (booking.status === 'confirmed') { %>
                  <form method="POST" action="/admin/bookings/status" onsubmit="return confirm('标记为已完成？')">
                    <input type="hidden" name="id" value="<%= booking.id %>">
                    <input type="hidden" name="status" value="completed">
                    <input type="hidden" name="redirect" value="/admin/bookings/detail/<%= booking.id %>">
                    <button class="btn btn-info">🎉 标记完成</button>
                  </form>
                  <form method="POST" action="/admin/bookings/status" onsubmit="return confirm('取消该订单？')">
                    <input type="hidden" name="id" value="<%= booking.id %>">
                    <input type="hidden" name="status" value="cancelled">
                    <input type="hidden" name="redirect" value="/admin/bookings/detail/<%= booking.id %>">
                    <button class="btn btn-danger">❌ 取消订单</button>
                  </form>
                <% } else if (booking.status === 'completed') { %>
                  <p style="color:#155724;font-size:14px;">✅ 该订单已完成，不可更改状态</p>
                <% } else { %>
                  <p style="color:#721c24;font-size:14px;">❌ 该订单已取消</p>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
