<% let path='/nearby'; let title=__('site.title.nearby'); %>
<%- include('partials/header', { path, title }) %>

<style>
  .nearby-hero {
    background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
    padding: 50px 20px; text-align: center; color: #fff;
  }
  .nearby-hero h1 { font-size: 36px; margin: 0 0 10px; }
  .nearby-hero p { font-size: 16px; opacity: 0.9; margin: 0 0 20px; }
  .locate-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 30px; background: #fff; color: #1a73e8;
    border: none; border-radius: 30px; font-size: 16px; font-weight: 600;
    cursor: pointer; transition: all 0.3s; box-shadow: 0 4px 15px rgba(0,0,0,0.2);
  }
  .locate-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.3); }
  .locate-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .locate-status {
    margin-top: 12px; font-size: 14px; opacity: 0.85;
    display: flex; align-items: center; justify-content: center; gap: 8px;
  }
  .locate-status .spinner {
    width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.3);
    border-top: 2px solid #fff; border-radius: 50%; animation: spin 0.8s linear infinite;
    display: none;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .nearby-stats {
    display: flex; justify-content: center; gap: 30px;
    padding: 20px; background: #f8f9fa; flex-wrap: wrap;
  }
  .nearby-stats .stat { text-align: center; }
  .nearby-stats .stat .num { font-size: 28px; font-weight: 700; color: #1a73e8; }
  .nearby-stats .stat .label { font-size: 13px; color: #666; }

  .city-section { max-width: 1400px; margin: 0 auto; padding: 30px 15px; }
  .city-header {
    display: flex; align-items: center; gap: 12px; margin-bottom: 20px;
  }
  .city-header h2 { font-size: 24px; color: #2c3e50; margin: 0; }
  .city-header .city-badge {
    background: #e3f2fd; color: #1a73e8; padding: 4px 12px;
    border-radius: 20px; font-size: 12px; font-weight: 600;
  }
  .city-divider { border: none; border-top: 2px dashed #e0e0e0; margin: 0 0 25px; }

  .tour-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px; margin-bottom: 30px;
  }
  .tour-card {
    background: #fff; border-radius: 14px; overflow: hidden;
    box-shadow: 0 2px 15px rgba(0,0,0,0.05); transition: all 0.35s ease;
    border: 1px solid #f0f0f0;
  }
  .tour-card:hover {
    transform: translateY(-5px); box-shadow: 0 12px 35px rgba(0,0,0,0.12);
  }
  .tour-card .card-img {
    position: relative; height: 200px; overflow: hidden;
  }
  .tour-card .card-img img {
    width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s;
  }
  .tour-card:hover .card-img img { transform: scale(1.08); }
  .tour-card .card-img .tag {
    position: absolute; top: 12px; left: 0;
    background: #1a73e8; color: #fff; padding: 4px 14px; font-size: 12px; font-weight: 600;
    border-radius: 0 4px 4px 0;
  }
  .tour-card .card-img .distance-badge {
    position: absolute; bottom: 12px; right: 12px;
    background: rgba(0,0,0,0.6); color: #fff; padding: 3px 10px;
    border-radius: 15px; font-size: 12px; font-weight: 600;
  }
  .tour-card .card-img .loc-icon {
    position: absolute; bottom: 12px; left: 12px;
    background: rgba(0,0,0,0.6); color: #fff; padding: 3px 10px;
    border-radius: 15px; font-size: 12px;
  }
  .tour-card .card-body { padding: 16px 18px; }
  .tour-card .card-body h3 {
    font-size: 15px; color: #2c3e50; margin: 0 0 6px;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 600;
  }
  .tour-card .card-body .desc {
    color: #7f8c8d; font-size: 13px; line-height: 1.5; margin: 0 0 12px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .tour-card .card-body .meta {
    display: flex; justify-content: space-between; align-items: center;
    padding-top: 12px; border-top: 1px solid #f0f0f0;
  }
  .tour-card .card-body .meta .price { color: #ff6600; font-size: 14px; font-weight: 600; }
  .tour-card .card-body .meta .price b { font-size: 20px; }
  .tour-card .card-body .meta .rating { color: #95a5a6; font-size: 13px; }

  @media (max-width: 768px) {
    .nearby-hero h1 { font-size: 24px; }
    .tour-grid { grid-template-columns: 1fr; }
    .nearby-stats { gap: 15px; }
  }
</style>

<div class="nearby-hero">
  <h1>📍 <%= __('nearby.title') %></h1>
  <p><%= __('nearby.desc') %></p>
  <button class="locate-btn" id="locateBtn" onclick="getLocation()">
    📍 <span id="locateText"><%= __('nearby.locateBtn') %></span>
  </button>
  <div class="locate-status">
    <div class="spinner" id="locateSpinner"></div>
    <span id="locateStatus"><%= __('nearby.locateHint') %></span>
  </div>
</div>

<div class="nearby-stats">
  <div class="stat">
    <div class="num"><%= tours.length %></div>
    <div class="label"><%= __('nearby.totalTours') %></div>
  </div>
  <div class="stat">
    <div class="num"><%= totalCities %></div>
    <div class="label"><%= __('nearby.totalCities') %></div>
  </div>
  <div class="stat">
    <div class="num">500<%= isEn ? 'km' : '公里' %></div>
    <div class="label"><%= __('nearby.coverage') %></div>
  </div>
</div>

<% cityGroups.forEach(function(group) { var city = group[0]; var cityTours = group[1]; %>
<div class="city-section" data-city="<%= city %>">
  <div class="city-header">
    <h2>📍 <%= city %></h2>
    <span class="city-badge"><%= cityTours.length %> <%= isEn ? 'tours' : '条线路' %></span>
  </div>
  <hr class="city-divider">
  <div class="tour-grid">
    <% cityTours.forEach(function(tour) { %>
    <a href="/tour/<%= tour.id %><%= isEn ? '?lang=en' : '' %>" style="text-decoration:none;color:inherit;">
      <div class="tour-card">
        <div class="card-img">
          <img src="/img/<%= tour.image %>" alt="<%= tt(tour, 'title') %>">
          <span class="tag"><%= tt(tour, 'type_label') %></span>
          <span class="loc-icon">📍 <%= tour.city %></span>
          <% if (tour.distance) { %>
            <span class="distance-badge">📏 <%= tour.distance %>km</span>
          <% } %>
        </div>
        <div class="card-body">
          <h3><%= tt(tour, 'title') %></h3>
          <p class="desc"><%= tt(tour, 'description') %></p>
          <div class="meta">
            <span class="price">¥&nbsp;<b><%= tour.price %></b><%= isEn ? " from" : "起" %></span>
            <span class="rating">⭐ <%= tour.satisfaction %></span>
          </div>
        </div>
      </div>
    </a>
    <% }); %>
  </div>
</div>
<% }); %>

<script>
// Get user location
function getLocation() {
  var btn = document.getElementById('locateBtn');
  var status = document.getElementById('locateStatus');
  var text = document.getElementById('locateText');
  var spinner = document.getElementById('locateSpinner');
  
  if (!navigator.geolocation) {
    status.textContent = '<%= __('nearby.noGeolocation') %>';
    return;
  }
  
  btn.disabled = true;
  text.textContent = '<%= isEn ? "Locating..." : "定位中..." %>';
  spinner.style.display = 'inline-block';
  status.textContent = '<%= isEn ? "Getting your location..." : "正在获取您的位置..." %>';
  
  navigator.geolocation.getCurrentPosition(
    function(pos) {
      var lat = pos.coords.latitude;
      var lng = pos.coords.longitude;
      
      // Save location to server
      fetch('/api/user/location', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ latitude: lat, longitude: lng })
      }).then(function(r) { return r.json(); }).then(function(d) {
        if (d.success) {
          status.innerHTML = '✅ <%= isEn ? "Location found! Refreshing..." : "已获取位置！正在刷新..." %>';
          setTimeout(function() { window.location.reload(); }, 1000);
        }
      });
    },
    function(err) {
      btn.disabled = false;
      text.textContent = '<%= __('nearby.locateBtn') %>';
      spinner.style.display = 'none';
      status.textContent = '❌ ' + (
        err.code === 1 ? '<%= isEn ? "Please allow location access" : "请允许获取位置信息" %>' :
        err.code === 2 ? '<%= isEn ? "Location unavailable" : "无法获取位置" %>' :
        '<%= isEn ? "Location request timed out" : "定位超时" %>'
      );
    },
    { enableHighAccuracy: true, timeout: 10000, maximumAge: 300000 }
  );
}

<% if (userLocation) { %>
// Show current location info
document.addEventListener('DOMContentLoaded', function() {
  var lat = <%= userLocation.latitude %>;
  var lng = <%= userLocation.longitude %>;
  document.getElementById('locateText').textContent = '📍 <%= isEn ? "Located" : "已定位" %>';
  document.getElementById('locateStatus').innerHTML = '✅ <%= isEn ? "Current location: " : "当前位置: " %>' + lat.toFixed(2) + ', ' + lng.toFixed(2);
});
<% } %>
</script>

<%- include('partials/footer') %>
